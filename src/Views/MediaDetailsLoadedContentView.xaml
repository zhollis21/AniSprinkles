<?xml version="1.0" encoding="utf-8" ?>
<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:pageModels="clr-namespace:AniSprinkles.PageModels"
             xmlns:views="clr-namespace:AniSprinkles.Views"
             x:Class="AniSprinkles.Views.MediaDetailsLoadedContentView"
             x:DataType="pageModels:MediaDetailsPageModel">
    <ScrollView>
        <VerticalStackLayout Spacing="16">
            <Image HeightRequest="150"
                   Aspect="AspectFill"
                   Source="{Binding BannerImageUrl}"
                   IsVisible="{Binding HasBannerImage}" />

            <HorizontalStackLayout Spacing="16">
                <Image WidthRequest="120"
                       HeightRequest="170"
                       Aspect="AspectFill"
                       Source="{Binding CoverImageUrl}"
                       IsVisible="{Binding CoverImageUrl, Converter={StaticResource StringNotNullOrEmptyConverter}}" />

                <VerticalStackLayout Spacing="6">
                    <Label Text="{Binding PageTitle}"
                           FontSize="24"
                           FontAttributes="Bold" />
                    <Label Text="{Binding Media.Title.Romaji, StringFormat='Romaji: {0}'}"
                           FontSize="12"
                           TextColor="{StaticResource Gray400}"
                           IsVisible="{Binding Media.Title.Romaji, Converter={StaticResource StringNotNullOrEmptyConverter}}" />
                    <Label Text="{Binding Media.Title.Native, StringFormat='Native: {0}'}"
                           FontSize="12"
                           TextColor="{StaticResource Gray400}"
                           IsVisible="{Binding Media.Title.Native, Converter={StaticResource StringNotNullOrEmptyConverter}}" />
                    <Label Text="{Binding Media.Id, StringFormat='AniList ID: {0}'}"
                           FontSize="12"
                           TextColor="{StaticResource Gray400}" />
                    <Label Text="{Binding Media.IdMal, StringFormat='MAL ID: {0}'}"
                           FontSize="12"
                           TextColor="{StaticResource Gray400}"
                           IsVisible="{Binding HasMalId}" />
                </VerticalStackLayout>
            </HorizontalStackLayout>

            <Grid ColumnDefinitions="*,*"
                  RowDefinitions="Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto"
                  ColumnSpacing="12"
                  RowSpacing="6">
                <Label Grid.Row="0" Grid.Column="0" Text="{Binding Media.Format, StringFormat='Format: {0}', TargetNullValue='Format: -'}" FontSize="12" TextColor="{StaticResource Gray400}" />
                <Label Grid.Row="0" Grid.Column="1" Text="{Binding Media.Status, StringFormat='Status: {0}', TargetNullValue='Status: -'}" FontSize="12" TextColor="{StaticResource Gray400}" />

                <Label Grid.Row="1" Grid.Column="0" Text="{Binding Media.Episodes, StringFormat='Episodes: {0}', TargetNullValue='Episodes: -'}" FontSize="12" TextColor="{StaticResource Gray400}" />
                <Label Grid.Row="1" Grid.Column="1" Text="{Binding DurationDisplay, StringFormat='Duration: {0}'}" FontSize="12" TextColor="{StaticResource Gray400}" />

                <Label Grid.Row="2" Grid.Column="0" Text="{Binding SeasonDisplay, StringFormat='Season: {0}'}" FontSize="12" TextColor="{StaticResource Gray400}" />
                <Label Grid.Row="2" Grid.Column="1" Text="{Binding SourceDisplay, StringFormat='Source: {0}'}" FontSize="12" TextColor="{StaticResource Gray400}" />

                <Label Grid.Row="3" Grid.Column="0" Text="{Binding CountryDisplay, StringFormat='Country: {0}'}" FontSize="12" TextColor="{StaticResource Gray400}" />
                <Label Grid.Row="3" Grid.Column="1" Text="{Binding AdultDisplay, StringFormat='Content: {0}'}" FontSize="12" TextColor="{StaticResource Gray400}" />

                <Label Grid.Row="4" Grid.Column="0" Text="{Binding LicensedDisplay, StringFormat='Licensed: {0}'}" FontSize="12" TextColor="{StaticResource Gray400}" />
                <Label Grid.Row="4" Grid.Column="1" Text="{Binding ReleaseWindowDisplay, StringFormat='Release: {0}'}" FontSize="12" TextColor="{StaticResource Gray400}" />

                <Label Grid.Row="5" Grid.Column="0" Text="{Binding NextAiringDisplay, StringFormat='Next Airing: {0}'}" FontSize="12" TextColor="{StaticResource Gray400}" />
                <Label Grid.Row="5" Grid.Column="1" Text="{Binding Media.AverageScore, StringFormat='Avg Score: {0}', TargetNullValue='Avg Score: -'}" FontSize="12" TextColor="{StaticResource Gray400}" />

                <Label Grid.Row="6" Grid.Column="0" Text="{Binding Media.MeanScore, StringFormat='Mean Score: {0}', TargetNullValue='Mean Score: -'}" FontSize="12" TextColor="{StaticResource Gray400}" />
                <Label Grid.Row="6" Grid.Column="1" Text="{Binding Media.Popularity, StringFormat='Popularity: {0}', TargetNullValue='Popularity: -'}" FontSize="12" TextColor="{StaticResource Gray400}" />

                <Label Grid.Row="7" Grid.Column="0" Text="{Binding Media.Favourites, StringFormat='Favourites: {0}', TargetNullValue='Favourites: -'}" FontSize="12" TextColor="{StaticResource Gray400}" />
                <Label Grid.Row="7" Grid.Column="1" Text="{Binding Media.Trending, StringFormat='Trending: {0}', TargetNullValue='Trending: -'}" FontSize="12" TextColor="{StaticResource Gray400}" />
            </Grid>

            <VerticalStackLayout Spacing="6"
                                 IsVisible="{Binding HasListEntry}">
                <Label Text="Your List"
                       FontSize="16"
                       FontAttributes="Bold" />
                <Label Text="{Binding ListEntry.StatusDisplay, StringFormat='Status: {0}'}"
                       FontSize="12"
                       TextColor="{StaticResource Gray400}" />
                <Label Text="{Binding ListEntry.ProgressDisplay, StringFormat='Progress: {0}'}"
                       FontSize="12"
                       TextColor="{StaticResource Gray400}" />
                <Label Text="{Binding ListEntry.ScoreDisplay, StringFormat='Score: {0}'}"
                       FontSize="12"
                       TextColor="{StaticResource Gray400}" />
            </VerticalStackLayout>

            <views:MediaDetailsExtendedSectionsView />
        </VerticalStackLayout>
    </ScrollView>
</ContentView>
