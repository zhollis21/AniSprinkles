<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:pageModels="clr-namespace:AniSprinkles.PageModels"
             xmlns:models="clr-namespace:AniSprinkles.Models"
             x:Class="AniSprinkles.Pages.MyAnimePage"
             x:DataType="pageModels:MyAnimePageModel"
             Title="{Binding Title}">

    <Grid Padding="24" RowDefinitions="Auto,Auto,*" RowSpacing="12">
        <Grid ColumnDefinitions="*,Auto,Auto" ColumnSpacing="10">
            <Label Text="My Anime" FontSize="28" FontAttributes="Bold" VerticalOptions="Center" />
            <Button Grid.Column="1"
                    Text="Sign In"
                    Command="{Binding SignInCommand}"
                    IsVisible="{Binding IsNotAuthenticated}" />
            <Button Grid.Column="2"
                    Text="Sign Out"
                    Command="{Binding SignOutCommand}"
                    IsVisible="{Binding IsAuthenticated}" />
        </Grid>

        <HorizontalStackLayout Grid.Row="1" Spacing="12">
            <ActivityIndicator IsRunning="{Binding IsBusy}" IsVisible="{Binding IsBusy}" />
            <Label Text="{Binding StatusMessage}"
                   IsVisible="{Binding HasStatusMessage}"
                   FontSize="12"
                   TextColor="{StaticResource Gray400}" />
        </HorizontalStackLayout>

        <CollectionView Grid.Row="2"
                        ItemsSource="{Binding Entries}"
                        IsVisible="{Binding IsAuthenticated}">
            <CollectionView.ItemTemplate>
                <DataTemplate x:DataType="models:MediaListEntry">
                    <Grid Padding="12" RowSpacing="6">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <Label Grid.Row="0" Grid.Column="0"
                               Text="{Binding Media.DisplayTitle}"
                               FontSize="16"
                               LineBreakMode="TailTruncation" />
                        <Label Grid.Row="0" Grid.Column="1"
                               Text="{Binding StatusDisplay}"
                               FontSize="12"
                               HorizontalOptions="End" />

                        <Label Grid.Row="1" Grid.Column="0"
                               Text="{Binding ProgressDisplay}"
                               FontSize="12"
                               TextColor="{StaticResource Gray400}" />
                        <Label Grid.Row="1" Grid.Column="1"
                               Text="{Binding ScoreDisplay, StringFormat='Score: {0}'}"
                               FontSize="12"
                               HorizontalOptions="End"
                               TextColor="{StaticResource Gray400}" />
                    </Grid>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>
    </Grid>
</ContentPage>
