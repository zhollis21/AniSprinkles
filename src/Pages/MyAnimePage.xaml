<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:pageModels="clr-namespace:AniSprinkles.PageModels"
             xmlns:views="clr-namespace:AniSprinkles.Views"
             xmlns:icons="clr-namespace:IconFont.Maui.FluentIcons;assembly=IconFont.Maui.FluentIcons"
             x:Class="AniSprinkles.Pages.MyAnimePage"
             x:DataType="pageModels:MyAnimePageModel"
             Title="{Binding Title}"
             Shell.TitleColor="{Binding Title, Converter={StaticResource RainbowAccentConverter}}">

    <ContentPage.ToolbarItems>
        <ToolbarItem x:Name="SearchToolbarItem"
                     Command="{Binding ToggleSearchCommand}"
                     Order="Primary">
            <ToolbarItem.IconImageSource>
                <FontImageSource Glyph="{x:Static icons:FluentIconsRegular.Search24}"
                                 FontFamily="{x:Static icons:FluentIconsRegular.FontFamily}"
                                 Color="{AppThemeBinding Light={StaticResource DarkOnLightBackground}, Dark={StaticResource LightOnDarkBackground}}"
                                 Size="20" />
            </ToolbarItem.IconImageSource>
        </ToolbarItem>
        <ToolbarItem x:Name="ViewModeToolbarItem"
                     Command="{Binding CycleViewModeCommand}"
                     Order="Primary">
            <ToolbarItem.IconImageSource>
                <FontImageSource x:Name="ViewModeIcon"
                                 Glyph="{x:Static icons:FluentIconsRegular.List24}"
                                 FontFamily="{x:Static icons:FluentIconsRegular.FontFamily}"
                                 Color="{AppThemeBinding Light={StaticResource DarkOnLightBackground}, Dark={StaticResource LightOnDarkBackground}}"
                                 Size="20" />
            </ToolbarItem.IconImageSource>
        </ToolbarItem>
    </ContentPage.ToolbarItems>

    <Grid Padding="{StaticResource LayoutPadding}">
        <!-- Not authenticated state -->
        <VerticalStackLayout Spacing="16"
                             VerticalOptions="Center"
                             IsVisible="{Binding ShowLoginPrompt}">
            <Border Style="{StaticResource CardStyle}" Padding="20">
                <VerticalStackLayout Spacing="12" HorizontalOptions="Center">
                    <Image HorizontalOptions="Center" WidthRequest="48" HeightRequest="48">
                        <Image.Source>
                            <FontImageSource Glyph="{x:Static icons:FluentIconsRegular.AppsList24}"
                                             FontFamily="{x:Static icons:FluentIconsRegular.FontFamily}"
                                             Color="{StaticResource Gray400}"
                                             Size="48" />
                        </Image.Source>
                    </Image>
                    <Label Text="Sign in to AniList"
                           Style="{StaticResource Title3}"
                           HorizontalTextAlignment="Center" />
                    <Label Text="Connect your account to view and update your anime lists."
                           Style="{StaticResource Caption1}"
                           TextColor="{StaticResource Gray400}"
                           HorizontalTextAlignment="Center" />
                    <views:AuthActionsView HorizontalOptions="Center" Margin="0,4,0,0" />
                </VerticalStackLayout>
            </Border>
        </VerticalStackLayout>

        <!-- Auth pending overlay -->
        <VerticalStackLayout Spacing="8"
                             HorizontalOptions="Center"
                             VerticalOptions="Center"
                             IsVisible="{Binding IsAuthenticationPending}">
            <ActivityIndicator IsRunning="True" IsVisible="True" />
            <Label Text="Checking authentication..."
                   Style="{StaticResource Caption1}"
                   TextColor="{StaticResource Gray400}" />
        </VerticalStackLayout>

        <!-- Loading overlay -->
        <VerticalStackLayout Spacing="8"
                             HorizontalOptions="Center"
                             VerticalOptions="Center"
                             IsVisible="{Binding IsInitialLoading}">
            <ActivityIndicator IsRunning="{Binding IsInitialLoading}"
                               IsVisible="{Binding IsInitialLoading}" />
            <Label Text="Loading anime list..."
                   Style="{StaticResource Caption1}"
                   TextColor="{StaticResource Gray400}" />
        </VerticalStackLayout>

        <!-- Error state (full-page, replaces loaded content when API fails with no cached data) -->
        <ScrollView IsVisible="{Binding IsErrorState}"
                    VerticalOptions="Center">
            <views:ErrorStateView ErrorTitle="{Binding ErrorTitle}"
                                  ErrorSubtitle="{Binding ErrorSubtitle}"
                                  ErrorIconGlyph="{Binding ErrorIconGlyph}"
                                  ErrorAccentColor="{StaticResource RainbowOrange}"
                                  RetryCommand="{Binding RetryLoadCommand}"
                                  ErrorDetails="{Binding ErrorDetails}"
                                  Margin="0,24" />
        </ScrollView>

        <!-- Loaded content host: heavy UI created programmatically after data loads -->
        <ContentView x:Name="LoadedContentHost" />
    </Grid>
</ContentPage>
