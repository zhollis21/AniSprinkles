<?xml version="1.0" encoding="utf-8" ?>
<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:pageModels="clr-namespace:AniSprinkles.PageModels"
             xmlns:models="clr-namespace:AniSprinkles.Models"
             xmlns:icons="clr-namespace:IconFont.Maui.FluentIcons;assembly=IconFont.Maui.FluentIcons"
             x:Class="AniSprinkles.Views.MediaDetailsLoadedContentView"
             x:DataType="pageModels:MediaDetailsPageModel"
             x:Name="RootView">

    <ScrollView>
        <VerticalStackLayout Padding="{StaticResource LayoutPadding}" Spacing="16">

            <!-- ============================================ -->
            <!-- 1. HERO: Banner + Cover + Title -->
            <!-- ============================================ -->
            <Border Style="{StaticResource CardStyle}" Padding="0">
                <Grid RowDefinitions="200,*">
                    <!-- Banner image -->
                    <Image Grid.Row="0"
                           Source="{Binding BannerImageUrl}"
                           Aspect="AspectFill"
                           IsVisible="{Binding HasBannerImage}">
                        <Image.Clip>
                            <RoundRectangleGeometry Rect="0,0,800,200" CornerRadius="16,16,0,0" />
                        </Image.Clip>
                    </Image>
                    <!-- Fallback colour block when no banner -->
                    <BoxView Grid.Row="0"
                             BackgroundColor="{Binding PageTitle, Converter={StaticResource RainbowAccentConverter}}"
                             Opacity="0.25"
                             IsVisible="{Binding HasBannerImage, Converter={StaticResource InvertedBoolConverter}}" />
                    <!-- Gradient overlay for readability -->
                    <BoxView Grid.Row="0">
                        <BoxView.Background>
                            <LinearGradientBrush StartPoint="0,0.4" EndPoint="0,1">
                                <GradientStop Color="Transparent" Offset="0" />
                                <GradientStop Color="#CC000000" Offset="1" />
                            </LinearGradientBrush>
                        </BoxView.Background>
                    </BoxView>

                    <!-- Cover + Title overlay -->
                    <Grid Grid.Row="0" Grid.RowSpan="2"
                          ColumnDefinitions="120,*"
                          ColumnSpacing="14"
                          VerticalOptions="End"
                          Padding="16,0,16,16">
                        <!-- Cover poster -->
                        <Border Grid.Column="0"
                                WidthRequest="120" HeightRequest="170"
                                StrokeShape="RoundRectangle 10"
                                StrokeThickness="2"
                                Stroke="{AppThemeBinding Light={StaticResource LightSecondaryBackground}, Dark={StaticResource DarkSecondaryBackground}}"
                                Padding="0"
                                Margin="0,60,0,0">
                            <Image Source="{Binding CoverImageUrl}"
                                   Aspect="AspectFill"
                                   WidthRequest="120"
                                   HeightRequest="170" />
                        </Border>
                        <!-- Title stack -->
                        <VerticalStackLayout Grid.Column="1" Spacing="6" VerticalOptions="End">
                            <Label Text="{Binding Media.DisplayTitle}"
                                   Style="{StaticResource Title1}"
                                   TextColor="{Binding PageTitle, Converter={StaticResource RainbowAccentConverter}}"
                                   MaxLines="3"
                                   LineBreakMode="TailTruncation">
                                <Label.Shadow>
                                    <Shadow Brush="Black" Offset="0,0" Radius="8" Opacity="0.9" />
                                </Label.Shadow>
                            </Label>
                            <HorizontalStackLayout Spacing="8">
                                <Label Text="{Binding FormatDisplay}"
                                       Style="{StaticResource Caption1Strong}"
                                       TextColor="{StaticResource Gray400}">
                                    <Label.Shadow><Shadow Brush="Black" Offset="0,0" Radius="6" Opacity="0.8" /></Label.Shadow>
                                </Label>
                                <Label Text="|" Style="{StaticResource Caption1}" TextColor="{StaticResource Gray400}">
                                    <Label.Shadow><Shadow Brush="Black" Offset="0,0" Radius="6" Opacity="0.8" /></Label.Shadow>
                                </Label>
                                <Label Text="{Binding StatusFormatted}"
                                       Style="{StaticResource Caption1Strong}"
                                       TextColor="{StaticResource Gray400}">
                                    <Label.Shadow><Shadow Brush="Black" Offset="0,0" Radius="6" Opacity="0.8" /></Label.Shadow>
                                </Label>
                            </HorizontalStackLayout>
                        </VerticalStackLayout>
                    </Grid>
                </Grid>
            </Border>

            <!-- ============================================ -->
            <!-- 2. STAT PILLS: Score, Popularity, Favourites -->
            <!-- ============================================ -->
            <Grid ColumnDefinitions="*,*,*" ColumnSpacing="10">
                <!-- Score pill -->
                <Border Grid.Column="0" Style="{StaticResource CardStyle}" Padding="10,10">
                    <VerticalStackLayout Spacing="2" HorizontalOptions="Center">
                        <Image WidthRequest="18" HeightRequest="18" HorizontalOptions="Center">
                            <Image.Source>
                                <FontImageSource Glyph="{x:Static icons:FluentIconsRegular.Star24}"
                                                 FontFamily="{x:Static icons:FluentIconsRegular.FontFamily}"
                                                 Color="{Binding Converter={StaticResource RainbowAccentConverter}, ConverterParameter='Score'}"
                                                 Size="18" />
                            </Image.Source>
                        </Image>
                        <Label Text="{Binding ScorePercentDisplay}" Style="{StaticResource Title2}" HorizontalTextAlignment="Center"
                               TextColor="{Binding Converter={StaticResource RainbowAccentConverter}, ConverterParameter='Score'}" />
                        <Label Text="Score" Style="{StaticResource Caption2}" TextColor="{StaticResource Gray400}" HorizontalTextAlignment="Center" />
                    </VerticalStackLayout>
                </Border>
                <!-- Popularity pill -->
                <Border Grid.Column="1" Style="{StaticResource CardStyle}" Padding="10,10">
                    <VerticalStackLayout Spacing="2" HorizontalOptions="Center">
                        <Image WidthRequest="18" HeightRequest="18" HorizontalOptions="Center">
                            <Image.Source>
                                <FontImageSource Glyph="{x:Static icons:FluentIconsRegular.People24}"
                                                 FontFamily="{x:Static icons:FluentIconsRegular.FontFamily}"
                                                 Color="{Binding Converter={StaticResource RainbowAccentConverter}, ConverterParameter='Popularity'}"
                                                 Size="18" />
                            </Image.Source>
                        </Image>
                        <Label Text="{Binding PopularityDisplay}" Style="{StaticResource Title2}" HorizontalTextAlignment="Center"
                               TextColor="{Binding Converter={StaticResource RainbowAccentConverter}, ConverterParameter='Popularity'}" />
                        <Label Text="Popularity" Style="{StaticResource Caption2}" TextColor="{StaticResource Gray400}" HorizontalTextAlignment="Center" />
                    </VerticalStackLayout>
                </Border>
                <!-- Favourites pill -->
                <Border Grid.Column="2" Style="{StaticResource CardStyle}" Padding="10,10">
                    <VerticalStackLayout Spacing="2" HorizontalOptions="Center">
                        <Image WidthRequest="18" HeightRequest="18" HorizontalOptions="Center">
                            <Image.Source>
                                <FontImageSource Glyph="{x:Static icons:FluentIconsRegular.Heart24}"
                                                 FontFamily="{x:Static icons:FluentIconsRegular.FontFamily}"
                                                 Color="{Binding Converter={StaticResource RainbowAccentConverter}, ConverterParameter='Favourites'}"
                                                 Size="18" />
                            </Image.Source>
                        </Image>
                        <Label Text="{Binding FavouritesDisplay}" Style="{StaticResource Title2}" HorizontalTextAlignment="Center"
                               TextColor="{Binding Converter={StaticResource RainbowAccentConverter}, ConverterParameter='Favourites'}" />
                        <Label Text="Favourites" Style="{StaticResource Caption2}" TextColor="{StaticResource Gray400}" HorizontalTextAlignment="Center" />
                    </VerticalStackLayout>
                </Border>
            </Grid>

            <!-- ============================================ -->
            <!-- 3. QUICK INFO CHIPS -->
            <!-- ============================================ -->
            <FlexLayout Wrap="Wrap" JustifyContent="Start" AlignItems="Center">
                <Border Style="{StaticResource ChipBorderStyle}" Padding="10,6" Margin="0,0,6,6"
                        IsVisible="{Binding EpisodesDisplay, Converter={StaticResource StringNotNullOrEmptyConverter}}">
                    <Label Text="{Binding EpisodesDisplay}" Style="{StaticResource ChipLabelStyle}"
                           TextColor="{Binding Converter={StaticResource RainbowAccentConverter}, ConverterParameter='Episodes'}" />
                </Border>
                <Border Style="{StaticResource ChipBorderStyle}" Padding="10,6" Margin="0,0,6,6"
                        IsVisible="{Binding DurationPillDisplay, Converter={StaticResource StringNotNullOrEmptyConverter}}">
                    <Label Text="{Binding DurationPillDisplay}" Style="{StaticResource ChipLabelStyle}"
                           TextColor="{Binding Converter={StaticResource RainbowAccentConverter}, ConverterParameter='Duration'}" />
                </Border>
                <Border Style="{StaticResource ChipBorderStyle}" Padding="10,6" Margin="0,0,6,6"
                        IsVisible="{Binding SeasonYearDisplay, Converter={StaticResource StringNotNullOrEmptyConverter}}">
                    <Label Text="{Binding SeasonYearDisplay}" Style="{StaticResource ChipLabelStyle}"
                           TextColor="{Binding Converter={StaticResource RainbowAccentConverter}, ConverterParameter='Season'}" />
                </Border>
                <Border Style="{StaticResource ChipBorderStyle}" Padding="10,6" Margin="0,0,6,6"
                        IsVisible="{Binding HasMainStudio}">
                    <Label Text="{Binding MainStudioName}" Style="{StaticResource ChipLabelStyle}"
                           TextColor="{Binding Converter={StaticResource RainbowAccentConverter}, ConverterParameter='Studio'}" />
                </Border>
            </FlexLayout>

            <!-- ============================================ -->
            <!-- 3b. NEXT EPISODE AIRING COUNTDOWN -->
            <!-- ============================================ -->
            <Border Style="{StaticResource CardStyle}" Padding="12,10"
                    IsVisible="{Binding HasNextAiringInfo}">
                <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="10" RowDefinitions="Auto,Auto" RowSpacing="4">
                    <!-- Live icon -->
                    <Image Grid.Column="0" Grid.RowSpan="2" WidthRequest="20" HeightRequest="20"
                           VerticalOptions="Center">
                        <Image.Source>
                            <FontImageSource Glyph="{x:Static icons:FluentIconsRegular.Live24}"
                                             FontFamily="{x:Static icons:FluentIconsRegular.FontFamily}"
                                             Color="{StaticResource RainbowCyan}" Size="20" />
                        </Image.Source>
                    </Image>

                    <!-- Episode label + countdown -->
                    <HorizontalStackLayout Grid.Column="1" Grid.Row="0" Spacing="6" VerticalOptions="Center">
                        <Label Text="{Binding NextAiringEpisodeLabel}"
                               Style="{StaticResource Caption1Strong}"
                               TextColor="{StaticResource RainbowCyan}"
                               VerticalTextAlignment="Center" />
                        <Label Text="·" Style="{StaticResource Caption1}"
                               TextColor="{StaticResource Gray400}" VerticalTextAlignment="Center" />
                        <Label Text="{Binding NextAiringCountdownCompact}"
                               Style="{StaticResource Caption1Strong}"
                               TextColor="{StaticResource White}"
                               VerticalTextAlignment="Center" />
                    </HorizontalStackLayout>

                    <!-- Date subtitle -->
                    <Label Grid.Column="1" Grid.Row="1"
                           Text="{Binding NextAiringDateDisplay}"
                           Style="{StaticResource Caption2}"
                           TextColor="{StaticResource Gray400}" />

                    <!-- "Airing Today!" badge when < 24h -->
                    <Border Grid.Column="2" Grid.RowSpan="2"
                            StrokeShape="RoundRectangle 10" StrokeThickness="0"
                            BackgroundColor="{StaticResource RainbowCyan}"
                            Padding="8,4"
                            VerticalOptions="Center"
                            IsVisible="{Binding IsAiringToday}">
                        <Label Text="SOON" Style="{StaticResource Caption2}"
                               FontAttributes="Bold" FontSize="14" />
                    </Border>
                </Grid>
            </Border>

            <!-- ============================================ -->
            <!-- 4. LIST ENTRY EDITOR (unified card) -->
            <!-- ============================================ -->
            <Border Style="{StaticResource CardStyle}" Padding="14,12"
                    IsVisible="{Binding IsAuthenticated}">
                <VerticalStackLayout Spacing="14">

                    <!-- ── Status dropdown ── -->
                    <VerticalStackLayout Spacing="0">
                        <!-- Dropdown button -->
                        <Border StrokeShape="RoundRectangle 10" StrokeThickness="1"
                                Stroke="{Binding ListStatusDisplay, Converter={StaticResource RainbowAccentConverter}}"
                                BackgroundColor="Transparent" Padding="12,10">
                            <Border.GestureRecognizers>
                                <TapGestureRecognizer Command="{Binding ToggleStatusExpandedCommand}" />
                            </Border.GestureRecognizers>
                            <Grid ColumnDefinitions="Auto,*,Auto,Auto" ColumnSpacing="10">
                                <Image Grid.Column="0" WidthRequest="20" HeightRequest="20" VerticalOptions="Center">
                                    <Image.Source>
                                        <FontImageSource Glyph="{Binding StatusIconGlyph}"
                                                         FontFamily="{x:Static icons:FluentIconsRegular.FontFamily}"
                                                         Color="{Binding ListStatusDisplay, Converter={StaticResource RainbowAccentConverter}}"
                                                         Size="20" />
                                    </Image.Source>
                                </Image>
                                <Label Grid.Column="1" Text="{Binding ListStatusDisplay}"
                                       Style="{StaticResource Body1Strong}"
                                       TextColor="{Binding ListStatusDisplay, Converter={StaticResource RainbowAccentConverter}}"
                                       VerticalTextAlignment="Center" />
                                <ActivityIndicator Grid.Column="2" IsRunning="{Binding IsSavingListEntry}" IsVisible="{Binding IsSavingListEntry}"
                                                   WidthRequest="18" HeightRequest="18" VerticalOptions="Center" />
                                <!-- Chevron down when collapsed -->
                                <Image Grid.Column="3" WidthRequest="16" HeightRequest="16" VerticalOptions="Center"
                                       IsVisible="{Binding IsStatusExpanded, Converter={StaticResource InvertedBoolConverter}}">
                                    <Image.Source>
                                        <FontImageSource Glyph="{x:Static icons:FluentIconsRegular.ChevronDown24}"
                                                         FontFamily="{x:Static icons:FluentIconsRegular.FontFamily}"
                                                         Color="{StaticResource Gray400}" Size="16" />
                                    </Image.Source>
                                </Image>
                                <!-- Chevron up when expanded -->
                                <Image Grid.Column="3" WidthRequest="16" HeightRequest="16" VerticalOptions="Center"
                                       IsVisible="{Binding IsStatusExpanded}">
                                    <Image.Source>
                                        <FontImageSource Glyph="{x:Static icons:FluentIconsRegular.ChevronUp24}"
                                                         FontFamily="{x:Static icons:FluentIconsRegular.FontFamily}"
                                                         Color="{StaticResource Gray400}" Size="16" />
                                    </Image.Source>
                                </Image>
                            </Grid>
                        </Border>

                        <!-- ── Dropdown list ── -->
                        <Border StrokeShape="RoundRectangle 10" StrokeThickness="1"
                                Stroke="{StaticResource Gray600}" BackgroundColor="Transparent"
                                Padding="4,4" Margin="0,10,0,0"
                                IsVisible="{Binding IsStatusExpanded}">
                        <VerticalStackLayout Spacing="0">
                            <!-- Watching -->
                            <Border StrokeShape="RoundRectangle 8" StrokeThickness="0" Padding="10,10"
                                    Background="{Binding CurrentStatusKey, Converter={StaticResource SortFieldBackgroundConverter}, ConverterParameter=Current}">
                                <Border.GestureRecognizers><TapGestureRecognizer Command="{Binding QuickSetStatusCommand}" CommandParameter="Current" /></Border.GestureRecognizers>
                                <Grid ColumnDefinitions="Auto,*" ColumnSpacing="10">
                                    <Image Grid.Column="0" WidthRequest="18" HeightRequest="18" VerticalOptions="Center">
                                        <Image.Source><FontImageSource Glyph="{x:Static icons:FluentIconsRegular.Eye24}" FontFamily="{x:Static icons:FluentIconsRegular.FontFamily}" Color="{Binding CurrentStatusKey, Converter={StaticResource SortFieldSelectedTextConverter}, ConverterParameter='Current'}" Size="18" /></Image.Source>
                                    </Image>
                                    <Label Grid.Column="1" Text="Watching" Style="{StaticResource Body2}" TextColor="{Binding CurrentStatusKey, Converter={StaticResource SortFieldSelectedTextConverter}, ConverterParameter='Current'}" VerticalTextAlignment="Center" />
                                </Grid>
                            </Border>
                            <BoxView HeightRequest="1" Color="{StaticResource Gray600}" Opacity="0.3" />
                            <!-- Plan to Watch -->
                            <Border StrokeShape="RoundRectangle 8" StrokeThickness="0" Padding="10,10"
                                    Background="{Binding CurrentStatusKey, Converter={StaticResource SortFieldBackgroundConverter}, ConverterParameter=Planning}">
                                <Border.GestureRecognizers><TapGestureRecognizer Command="{Binding QuickSetStatusCommand}" CommandParameter="Planning" /></Border.GestureRecognizers>
                                <Grid ColumnDefinitions="Auto,*" ColumnSpacing="10">
                                    <Image Grid.Column="0" WidthRequest="18" HeightRequest="18" VerticalOptions="Center">
                                        <Image.Source><FontImageSource Glyph="{x:Static icons:FluentIconsRegular.Bookmark24}" FontFamily="{x:Static icons:FluentIconsRegular.FontFamily}" Color="{Binding CurrentStatusKey, Converter={StaticResource SortFieldSelectedTextConverter}, ConverterParameter='Planning'}" Size="18" /></Image.Source>
                                    </Image>
                                    <Label Grid.Column="1" Text="Plan to Watch" Style="{StaticResource Body2}" TextColor="{Binding CurrentStatusKey, Converter={StaticResource SortFieldSelectedTextConverter}, ConverterParameter='Planning'}" VerticalTextAlignment="Center" />
                                </Grid>
                            </Border>
                            <BoxView HeightRequest="1" Color="{StaticResource Gray600}" Opacity="0.3" />
                            <!-- Completed -->
                            <Border StrokeShape="RoundRectangle 8" StrokeThickness="0" Padding="10,10"
                                    Background="{Binding CurrentStatusKey, Converter={StaticResource SortFieldBackgroundConverter}, ConverterParameter=Completed}">
                                <Border.GestureRecognizers><TapGestureRecognizer Command="{Binding QuickSetStatusCommand}" CommandParameter="Completed" /></Border.GestureRecognizers>
                                <Grid ColumnDefinitions="Auto,*" ColumnSpacing="10">
                                    <Image Grid.Column="0" WidthRequest="18" HeightRequest="18" VerticalOptions="Center">
                                        <Image.Source><FontImageSource Glyph="{x:Static icons:FluentIconsRegular.CheckmarkCircle24}" FontFamily="{x:Static icons:FluentIconsRegular.FontFamily}" Color="{Binding CurrentStatusKey, Converter={StaticResource SortFieldSelectedTextConverter}, ConverterParameter='Completed'}" Size="18" /></Image.Source>
                                    </Image>
                                    <Label Grid.Column="1" Text="Completed" Style="{StaticResource Body2}" TextColor="{Binding CurrentStatusKey, Converter={StaticResource SortFieldSelectedTextConverter}, ConverterParameter='Completed'}" VerticalTextAlignment="Center" />
                                </Grid>
                            </Border>
                            <BoxView HeightRequest="1" Color="{StaticResource Gray600}" Opacity="0.3" />
                            <!-- Paused -->
                            <Border StrokeShape="RoundRectangle 8" StrokeThickness="0" Padding="10,10"
                                    Background="{Binding CurrentStatusKey, Converter={StaticResource SortFieldBackgroundConverter}, ConverterParameter=Paused}">
                                <Border.GestureRecognizers><TapGestureRecognizer Command="{Binding QuickSetStatusCommand}" CommandParameter="Paused" /></Border.GestureRecognizers>
                                <Grid ColumnDefinitions="Auto,*" ColumnSpacing="10">
                                    <Image Grid.Column="0" WidthRequest="18" HeightRequest="18" VerticalOptions="Center">
                                        <Image.Source><FontImageSource Glyph="{x:Static icons:FluentIconsRegular.PauseCircle24}" FontFamily="{x:Static icons:FluentIconsRegular.FontFamily}" Color="{Binding CurrentStatusKey, Converter={StaticResource SortFieldSelectedTextConverter}, ConverterParameter='Paused'}" Size="18" /></Image.Source>
                                    </Image>
                                    <Label Grid.Column="1" Text="Paused" Style="{StaticResource Body2}" TextColor="{Binding CurrentStatusKey, Converter={StaticResource SortFieldSelectedTextConverter}, ConverterParameter='Paused'}" VerticalTextAlignment="Center" />
                                </Grid>
                            </Border>
                            <BoxView HeightRequest="1" Color="{StaticResource Gray600}" Opacity="0.3" />
                            <!-- Dropped -->
                            <Border StrokeShape="RoundRectangle 8" StrokeThickness="0" Padding="10,10"
                                    Background="{Binding CurrentStatusKey, Converter={StaticResource SortFieldBackgroundConverter}, ConverterParameter=Dropped}">
                                <Border.GestureRecognizers><TapGestureRecognizer Command="{Binding QuickSetStatusCommand}" CommandParameter="Dropped" /></Border.GestureRecognizers>
                                <Grid ColumnDefinitions="Auto,*" ColumnSpacing="10">
                                    <Image Grid.Column="0" WidthRequest="18" HeightRequest="18" VerticalOptions="Center">
                                        <Image.Source><FontImageSource Glyph="{x:Static icons:FluentIconsRegular.DismissCircle24}" FontFamily="{x:Static icons:FluentIconsRegular.FontFamily}" Color="{Binding CurrentStatusKey, Converter={StaticResource SortFieldSelectedTextConverter}, ConverterParameter='Dropped'}" Size="18" /></Image.Source>
                                    </Image>
                                    <Label Grid.Column="1" Text="Dropped" Style="{StaticResource Body2}" TextColor="{Binding CurrentStatusKey, Converter={StaticResource SortFieldSelectedTextConverter}, ConverterParameter='Dropped'}" VerticalTextAlignment="Center" />
                                </Grid>
                            </Border>
                            <BoxView HeightRequest="1" Color="{StaticResource Gray600}" Opacity="0.3" />
                            <!-- Rewatching -->
                            <Border StrokeShape="RoundRectangle 8" StrokeThickness="0" Padding="10,10"
                                    Background="{Binding CurrentStatusKey, Converter={StaticResource SortFieldBackgroundConverter}, ConverterParameter=Repeating}">
                                <Border.GestureRecognizers><TapGestureRecognizer Command="{Binding QuickSetStatusCommand}" CommandParameter="Repeating" /></Border.GestureRecognizers>
                                <Grid ColumnDefinitions="Auto,*" ColumnSpacing="10">
                                    <Image Grid.Column="0" WidthRequest="18" HeightRequest="18" VerticalOptions="Center">
                                        <Image.Source><FontImageSource Glyph="{x:Static icons:FluentIconsRegular.ArrowRepeatAll24}" FontFamily="{x:Static icons:FluentIconsRegular.FontFamily}" Color="{Binding CurrentStatusKey, Converter={StaticResource SortFieldSelectedTextConverter}, ConverterParameter='Repeating'}" Size="18" /></Image.Source>
                                    </Image>
                                    <Label Grid.Column="1" Text="Rewatching" Style="{StaticResource Body2}" TextColor="{Binding CurrentStatusKey, Converter={StaticResource SortFieldSelectedTextConverter}, ConverterParameter='Repeating'}" VerticalTextAlignment="Center" />
                                </Grid>
                            </Border>
                            <!-- Remove from List -->
                            <BoxView HeightRequest="1" Color="{StaticResource Gray600}" Opacity="0.3"
                                     IsVisible="{Binding HasListEntry}" />
                            <Border StrokeShape="RoundRectangle 8" StrokeThickness="0" Padding="10,10"
                                    BackgroundColor="Transparent"
                                    IsVisible="{Binding HasListEntry}">
                                <Border.GestureRecognizers><TapGestureRecognizer Command="{Binding RemoveFromListCommand}" /></Border.GestureRecognizers>
                                <Grid ColumnDefinitions="Auto,*" ColumnSpacing="10">
                                    <Image Grid.Column="0" WidthRequest="18" HeightRequest="18" VerticalOptions="Center">
                                        <Image.Source><FontImageSource Glyph="{x:Static icons:FluentIconsRegular.Delete24}" FontFamily="{x:Static icons:FluentIconsRegular.FontFamily}" Color="{StaticResource Gray400}" Size="18" /></Image.Source>
                                    </Image>
                                    <Label Grid.Column="1" Text="Remove from List" Style="{StaticResource Body2}" TextColor="{StaticResource Gray400}" VerticalTextAlignment="Center" />
                                </Grid>
                            </Border>
                        </VerticalStackLayout>
                        </Border>
                    </VerticalStackLayout>

                    <!-- ── Progress ── -->
                    <VerticalStackLayout Spacing="6" IsVisible="{Binding HasListEntry}">
                        <Grid ColumnDefinitions="Auto,*,Auto,Auto,Auto" ColumnSpacing="8">
                            <Image Grid.Column="0" WidthRequest="16" HeightRequest="16" VerticalOptions="Center">
                                <Image.Source>
                                    <FontImageSource Glyph="{x:Static icons:FluentIconsRegular.Play24}"
                                                     FontFamily="{x:Static icons:FluentIconsRegular.FontFamily}"
                                                     Color="{Binding Converter={StaticResource RainbowAccentConverter}, ConverterParameter='Progress'}" Size="16" />
                                </Image.Source>
                            </Image>
                            <Label Grid.Column="1" Text="Progress" Style="{StaticResource Caption1Strong}"
                                   TextColor="{Binding Converter={StaticResource RainbowAccentConverter}, ConverterParameter='Progress'}" VerticalTextAlignment="Center" />
                            <Border Grid.Column="2" StrokeShape="RoundRectangle 8" StrokeThickness="1"
                                    Stroke="{StaticResource Gray600}" BackgroundColor="Transparent"
                                    Padding="8,4" VerticalOptions="Center">
                                <Border.GestureRecognizers><TapGestureRecognizer Command="{Binding EditProgressCommand}" /></Border.GestureRecognizers>
                                <HorizontalStackLayout Spacing="6">
                                    <Label Text="{Binding ProgressLabel}"
                                           Style="{StaticResource Body2Strong}" VerticalTextAlignment="Center" />
                                    <Image WidthRequest="14" HeightRequest="14" VerticalOptions="Center">
                                        <Image.Source>
                                            <FontImageSource Glyph="{x:Static icons:FluentIconsRegular.Edit24}"
                                                             FontFamily="{x:Static icons:FluentIconsRegular.FontFamily}"
                                                             Color="{Binding Converter={StaticResource RainbowAccentConverter}, ConverterParameter='Progress'}" Size="14" />
                                        </Image.Source>
                                    </Image>
                                </HorizontalStackLayout>
                            </Border>
                            <!-- Minus button -->
                            <Border Grid.Column="3" StrokeShape="RoundRectangle 18" StrokeThickness="1"
                                    Stroke="{StaticResource Gray600}" BackgroundColor="Transparent"
                                    Padding="0" HeightRequest="36" WidthRequest="36">
                                <Border.GestureRecognizers><TapGestureRecognizer Command="{Binding DecrementProgressCommand}" /></Border.GestureRecognizers>
                                <Image WidthRequest="18" HeightRequest="18" HorizontalOptions="Center" VerticalOptions="Center">
                                    <Image.Source>
                                        <FontImageSource Glyph="{x:Static icons:FluentIconsRegular.Subtract24}"
                                                         FontFamily="{x:Static icons:FluentIconsRegular.FontFamily}"
                                                         Color="{Binding Converter={StaticResource RainbowAccentConverter}, ConverterParameter='Progress'}" Size="18" />
                                    </Image.Source>
                                </Image>
                            </Border>
                            <!-- Plus button -->
                            <Border Grid.Column="4" StrokeShape="RoundRectangle 18" StrokeThickness="1"
                                    Stroke="{StaticResource Gray600}" BackgroundColor="Transparent"
                                    Padding="0" HeightRequest="36" WidthRequest="36">
                                <Border.GestureRecognizers><TapGestureRecognizer Command="{Binding IncrementProgressCommand}" /></Border.GestureRecognizers>
                                <Image WidthRequest="18" HeightRequest="18" HorizontalOptions="Center" VerticalOptions="Center">
                                    <Image.Source>
                                        <FontImageSource Glyph="{x:Static icons:FluentIconsRegular.Add24}"
                                                         FontFamily="{x:Static icons:FluentIconsRegular.FontFamily}"
                                                         Color="{Binding Converter={StaticResource RainbowAccentConverter}, ConverterParameter='Progress'}" Size="18" />
                                    </Image.Source>
                                </Image>
                            </Border>
                        </Grid>
                        <Slider Minimum="0" Maximum="{Binding ProgressSliderMax}"
                                Value="{Binding SliderProgress}"
                                IsVisible="{Binding HasProgressSliderMax}"
                                MinimumTrackColor="{Binding Converter={StaticResource RainbowAccentConverter}, ConverterParameter='Progress'}"
                                ThumbColor="{Binding Converter={StaticResource RainbowAccentConverter}, ConverterParameter='Progress'}" />
                    </VerticalStackLayout>

                    <!-- Divider -->
                    <BoxView HeightRequest="1" Color="{StaticResource Gray600}" Opacity="0.3"
                             IsVisible="{Binding HasListEntry}" />

                    <!-- ── Score ── -->
                    <VerticalStackLayout Spacing="8" IsVisible="{Binding HasListEntry}">
                        <HorizontalStackLayout Spacing="6">
                            <Image WidthRequest="16" HeightRequest="16" VerticalOptions="Center">
                                <Image.Source>
                                    <FontImageSource Glyph="{x:Static icons:FluentIconsRegular.Star24}"
                                                     FontFamily="{x:Static icons:FluentIconsRegular.FontFamily}"
                                                     Color="{Binding Converter={StaticResource RainbowAccentConverter}, ConverterParameter='MyScore'}" Size="16" />
                                </Image.Source>
                            </Image>
                            <Label Text="Score" Style="{StaticResource Caption1Strong}"
                                   TextColor="{Binding Converter={StaticResource RainbowAccentConverter}, ConverterParameter='MyScore'}" />
                        </HorizontalStackLayout>

                        <!-- Stars (Point5) -->
                        <HorizontalStackLayout Spacing="12" HorizontalOptions="Center" IsVisible="{Binding ScoreFormatIsStars}">
                            <Image WidthRequest="40" HeightRequest="40">
                                <Image.GestureRecognizers><TapGestureRecognizer Command="{Binding SetStarRatingCommand}" CommandParameter="1" /></Image.GestureRecognizers>
                                <Image.Source>
                                    <FontImageSource Glyph="{x:Static icons:FluentIconsRegular.Star24}"
                                                     FontFamily="{x:Static icons:FluentIconsRegular.FontFamily}"
                                                     Color="{Binding Star1Filled, Converter={StaticResource RainbowAccentConverter}}"
                                                     Size="40" />
                                </Image.Source>
                            </Image>
                            <Image WidthRequest="40" HeightRequest="40">
                                <Image.GestureRecognizers><TapGestureRecognizer Command="{Binding SetStarRatingCommand}" CommandParameter="2" /></Image.GestureRecognizers>
                                <Image.Source>
                                    <FontImageSource Glyph="{x:Static icons:FluentIconsRegular.Star24}"
                                                     FontFamily="{x:Static icons:FluentIconsRegular.FontFamily}"
                                                     Color="{Binding Star2Filled, Converter={StaticResource RainbowAccentConverter}}"
                                                     Size="40" />
                                </Image.Source>
                            </Image>
                            <Image WidthRequest="40" HeightRequest="40">
                                <Image.GestureRecognizers><TapGestureRecognizer Command="{Binding SetStarRatingCommand}" CommandParameter="3" /></Image.GestureRecognizers>
                                <Image.Source>
                                    <FontImageSource Glyph="{x:Static icons:FluentIconsRegular.Star24}"
                                                     FontFamily="{x:Static icons:FluentIconsRegular.FontFamily}"
                                                     Color="{Binding Star3Filled, Converter={StaticResource RainbowAccentConverter}}"
                                                     Size="40" />
                                </Image.Source>
                            </Image>
                            <Image WidthRequest="40" HeightRequest="40">
                                <Image.GestureRecognizers><TapGestureRecognizer Command="{Binding SetStarRatingCommand}" CommandParameter="4" /></Image.GestureRecognizers>
                                <Image.Source>
                                    <FontImageSource Glyph="{x:Static icons:FluentIconsRegular.Star24}"
                                                     FontFamily="{x:Static icons:FluentIconsRegular.FontFamily}"
                                                     Color="{Binding Star4Filled, Converter={StaticResource RainbowAccentConverter}}"
                                                     Size="40" />
                                </Image.Source>
                            </Image>
                            <Image WidthRequest="40" HeightRequest="40">
                                <Image.GestureRecognizers><TapGestureRecognizer Command="{Binding SetStarRatingCommand}" CommandParameter="5" /></Image.GestureRecognizers>
                                <Image.Source>
                                    <FontImageSource Glyph="{x:Static icons:FluentIconsRegular.Star24}"
                                                     FontFamily="{x:Static icons:FluentIconsRegular.FontFamily}"
                                                     Color="{Binding Star5Filled, Converter={StaticResource RainbowAccentConverter}}"
                                                     Size="40" />
                                </Image.Source>
                            </Image>
                        </HorizontalStackLayout>

                        <!-- Smileys (Point3) -->
                        <HorizontalStackLayout Spacing="24" HorizontalOptions="Center" IsVisible="{Binding ScoreFormatIsSmileys}">
                            <Image WidthRequest="44" HeightRequest="44" Opacity="{Binding SmileyHappySelected, Converter={StaticResource SortFieldOpacityConverter}, ConverterParameter=True}">
                                <Image.GestureRecognizers><TapGestureRecognizer Command="{Binding SetSmileyRatingCommand}" CommandParameter="3" /></Image.GestureRecognizers>
                                <Image.Source>
                                    <FontImageSource Glyph="{x:Static icons:FluentIconsRegular.EmojiLaugh24}"
                                                     FontFamily="{x:Static icons:FluentIconsRegular.FontFamily}"
                                                     Color="{StaticResource RainbowGreen}" Size="44" />
                                </Image.Source>
                            </Image>
                            <Image WidthRequest="44" HeightRequest="44" Opacity="{Binding SmileyNeutralSelected, Converter={StaticResource SortFieldOpacityConverter}, ConverterParameter=True}">
                                <Image.GestureRecognizers><TapGestureRecognizer Command="{Binding SetSmileyRatingCommand}" CommandParameter="2" /></Image.GestureRecognizers>
                                <Image.Source>
                                    <FontImageSource Glyph="{x:Static icons:FluentIconsRegular.EmojiMeh24}"
                                                     FontFamily="{x:Static icons:FluentIconsRegular.FontFamily}"
                                                     Color="{StaticResource RainbowYellow}" Size="44" />
                                </Image.Source>
                            </Image>
                            <Image WidthRequest="44" HeightRequest="44" Opacity="{Binding SmileySadSelected, Converter={StaticResource SortFieldOpacityConverter}, ConverterParameter=True}">
                                <Image.GestureRecognizers><TapGestureRecognizer Command="{Binding SetSmileyRatingCommand}" CommandParameter="1" /></Image.GestureRecognizers>
                                <Image.Source>
                                    <FontImageSource Glyph="{x:Static icons:FluentIconsRegular.EmojiSad24}"
                                                     FontFamily="{x:Static icons:FluentIconsRegular.FontFamily}"
                                                     Color="{StaticResource RainbowRed}" Size="44" />
                                </Image.Source>
                            </Image>
                        </HorizontalStackLayout>

                        <!-- Numeric slider (Point100, Point10, Point10Decimal) -->
                        <VerticalStackLayout Spacing="4" IsVisible="{Binding ScoreFormatIsNumeric}">
                            <Label Text="{Binding NumericScoreLabel}"
                                   Style="{StaticResource Title2}" HorizontalTextAlignment="Center"
                                   TextColor="{Binding Converter={StaticResource RainbowAccentConverter}, ConverterParameter='MyScore'}" />
                            <Slider Minimum="0" Maximum="{Binding NumericScoreMax}"
                                    Value="{Binding SliderScore}"
                                    MinimumTrackColor="{Binding Converter={StaticResource RainbowAccentConverter}, ConverterParameter='MyScore'}"
                                    ThumbColor="{Binding Converter={StaticResource RainbowAccentConverter}, ConverterParameter='MyScore'}" />
                        </VerticalStackLayout>
                    </VerticalStackLayout>

                </VerticalStackLayout>
            </Border>

            <!-- ============================================ -->
            <!-- 5. DESCRIPTION -->
            <!-- ============================================ -->
            <Border Style="{StaticResource CardStyle}" Padding="16"
                    IsVisible="{Binding HasDescription}">
                <VerticalStackLayout Spacing="8">
                    <Label Text="{Binding Media.Description}"
                           Style="{StaticResource Body2}"
                           TextColor="{StaticResource Gray400}"
                           TextType="Html"
                           MaxLines="{Binding DescriptionMaxLines}"
                           LineBreakMode="TailTruncation" />
                    <Label Style="{StaticResource Caption1Strong}"
                           TextColor="{Binding Converter={StaticResource RainbowAccentConverter}, ConverterParameter='ReadMore'}">
                        <Label.Text>
                            <Binding Path="IsDescriptionExpanded" StringFormat="{}{0}">
                                <Binding.FallbackValue>Read more</Binding.FallbackValue>
                            </Binding>
                        </Label.Text>
                        <Label.Triggers>
                            <DataTrigger TargetType="Label" Binding="{Binding IsDescriptionExpanded}" Value="True">
                                <Setter Property="Text" Value="Show less" />
                            </DataTrigger>
                            <DataTrigger TargetType="Label" Binding="{Binding IsDescriptionExpanded}" Value="False">
                                <Setter Property="Text" Value="Read more" />
                            </DataTrigger>
                        </Label.Triggers>
                        <Label.GestureRecognizers>
                            <TapGestureRecognizer Command="{Binding ToggleDescriptionCommand}" />
                        </Label.GestureRecognizers>
                    </Label>
                </VerticalStackLayout>
            </Border>

            <!-- ============================================ -->
            <!-- GENRES -->
            <!-- ============================================ -->
            <FlexLayout Wrap="Wrap" JustifyContent="Start" AlignItems="Center"
                        IsVisible="{Binding HasGenres}"
                        BindableLayout.ItemsSource="{Binding Genres}">
                <BindableLayout.ItemTemplate>
                    <DataTemplate x:DataType="x:String">
                        <Border Style="{StaticResource ChipBorderStyle}" Padding="10,6" Margin="0,0,6,6">
                            <Label Text="{Binding .}" Style="{StaticResource ChipLabelStyle}"
                                   TextColor="{Binding ., Converter={StaticResource RainbowAccentConverter}}" />
                        </Border>
                    </DataTemplate>
                </BindableLayout.ItemTemplate>
            </FlexLayout>

            <!-- ============================================ -->
            <!-- ADDITIONAL INFO (Rankings, metadata, trailer) -->
            <!-- ============================================ -->
            <Border Style="{StaticResource CardStyle}" Padding="16">
                <VerticalStackLayout Spacing="10">
                    <!-- Rankings (grouped by scope) -->
                    <VerticalStackLayout Spacing="8" IsVisible="{Binding HasRankings}"
                                         BindableLayout.ItemsSource="{Binding RankingGroups}">
                        <BindableLayout.ItemTemplate>
                            <DataTemplate x:DataType="models:RankingGroup">
                                <VerticalStackLayout Spacing="4">
                                    <Label Text="{Binding Title}" Style="{StaticResource Caption2}"
                                           TextColor="{StaticResource Gray400}" FontAttributes="Bold" />
                                    <VerticalStackLayout Spacing="2"
                                                         BindableLayout.ItemsSource="{Binding Items}">
                                        <BindableLayout.ItemTemplate>
                                            <DataTemplate x:DataType="models:MediaRanking">
                                                <HorizontalStackLayout Spacing="8">
                                                    <Image WidthRequest="16" HeightRequest="16" VerticalOptions="Center">
                                                        <Image.Source>
                                                            <FontImageSource Glyph="{x:Static icons:FluentIconsRegular.Trophy24}"
                                                                             FontFamily="{x:Static icons:FluentIconsRegular.FontFamily}"
                                                                             Color="{Binding Type, Converter={StaticResource RainbowAccentConverter}}"
                                                                             Size="16" />
                                                        </Image.Source>
                                                    </Image>
                                                    <Label Style="{StaticResource Caption1}"
                                                           TextColor="{Binding Type, Converter={StaticResource RainbowAccentConverter}}">
                                                        <Label.Text>
                                                            <MultiBinding StringFormat="#{0} {1}">
                                                                <Binding Path="Rank" />
                                                                <Binding Path="TypeLabel" />
                                                            </MultiBinding>
                                                        </Label.Text>
                                                    </Label>
                                                </HorizontalStackLayout>
                                            </DataTemplate>
                                        </BindableLayout.ItemTemplate>
                                    </VerticalStackLayout>
                                </VerticalStackLayout>
                            </DataTemplate>
                        </BindableLayout.ItemTemplate>
                    </VerticalStackLayout>

                    <BoxView HeightRequest="1" Color="{AppThemeBinding Light={StaticResource Gray200}, Dark={StaticResource Gray600}}"
                             IsVisible="{Binding HasRankings}" />

                    <!-- Info rows -->
                    <VerticalStackLayout Spacing="0">
                        <!-- Release Window -->
                        <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="10" Padding="0,8">
                            <Image Grid.Column="0" WidthRequest="16" HeightRequest="16" VerticalOptions="Center">
                                <Image.Source>
                                    <FontImageSource Glyph="{x:Static icons:FluentIconsRegular.Calendar24}"
                                                     FontFamily="{x:Static icons:FluentIconsRegular.FontFamily}"
                                                     Color="{StaticResource Gray400}" Size="16" />
                                </Image.Source>
                            </Image>
                            <Label Grid.Column="1" Text="Release Window" Style="{StaticResource Caption1}" TextColor="{StaticResource Gray400}" VerticalTextAlignment="Center" />
                            <Label Grid.Column="2" Text="{Binding ReleaseWindowDisplay}" Style="{StaticResource Caption1Strong}" VerticalTextAlignment="Center" />
                        </Grid>
                        <BoxView HeightRequest="1" Color="{AppThemeBinding Light={StaticResource Gray200}, Dark={StaticResource Gray600}}" Opacity="0.3" />

                        <!-- Source -->
                        <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="10" Padding="0,8">
                            <Image Grid.Column="0" WidthRequest="16" HeightRequest="16" VerticalOptions="Center">
                                <Image.Source>
                                    <FontImageSource Glyph="{x:Static icons:FluentIconsRegular.Book24}"
                                                     FontFamily="{x:Static icons:FluentIconsRegular.FontFamily}"
                                                     Color="{StaticResource Gray400}" Size="16" />
                                </Image.Source>
                            </Image>
                            <Label Grid.Column="1" Text="Source" Style="{StaticResource Caption1}" TextColor="{StaticResource Gray400}" VerticalTextAlignment="Center" />
                            <Label Grid.Column="2" Text="{Binding SourceDisplay}" Style="{StaticResource Caption1Strong}" VerticalTextAlignment="Center" />
                        </Grid>
                        <BoxView HeightRequest="1" Color="{AppThemeBinding Light={StaticResource Gray200}, Dark={StaticResource Gray600}}" Opacity="0.3" />

                        <!-- Country -->
                        <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="10" Padding="0,8">
                            <Image Grid.Column="0" WidthRequest="16" HeightRequest="16" VerticalOptions="Center">
                                <Image.Source>
                                    <FontImageSource Glyph="{x:Static icons:FluentIconsRegular.Globe24}"
                                                     FontFamily="{x:Static icons:FluentIconsRegular.FontFamily}"
                                                     Color="{StaticResource Gray400}" Size="16" />
                                </Image.Source>
                            </Image>
                            <Label Grid.Column="1" Text="Country" Style="{StaticResource Caption1}" TextColor="{StaticResource Gray400}" VerticalTextAlignment="Center" />
                            <Label Grid.Column="2" Text="{Binding CountryDisplay}" Style="{StaticResource Caption1Strong}" VerticalTextAlignment="Center" />
                        </Grid>
                        <BoxView HeightRequest="1" Color="{AppThemeBinding Light={StaticResource Gray200}, Dark={StaticResource Gray600}}" Opacity="0.3" />

                        <!-- Licensed -->
                        <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="10" Padding="0,8">
                            <Image Grid.Column="0" WidthRequest="16" HeightRequest="16" VerticalOptions="Center">
                                <Image.Source>
                                    <FontImageSource Glyph="{x:Static icons:FluentIconsRegular.CheckmarkCircle24}"
                                                     FontFamily="{x:Static icons:FluentIconsRegular.FontFamily}"
                                                     Color="{StaticResource Gray400}" Size="16" />
                                </Image.Source>
                            </Image>
                            <Label Grid.Column="1" Text="Licensed" Style="{StaticResource Caption1}" TextColor="{StaticResource Gray400}" VerticalTextAlignment="Center" />
                            <Label Grid.Column="2" Text="{Binding LicensedDisplay}" Style="{StaticResource Caption1Strong}" VerticalTextAlignment="Center" />
                        </Grid>
                        <BoxView HeightRequest="1" Color="{AppThemeBinding Light={StaticResource Gray200}, Dark={StaticResource Gray600}}" Opacity="0.3" />

                        <!-- Rating -->
                        <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="10" Padding="0,8">
                            <Image Grid.Column="0" WidthRequest="16" HeightRequest="16" VerticalOptions="Center">
                                <Image.Source>
                                    <FontImageSource Glyph="{x:Static icons:FluentIconsRegular.Shield24}"
                                                     FontFamily="{x:Static icons:FluentIconsRegular.FontFamily}"
                                                     Color="{StaticResource Gray400}" Size="16" />
                                </Image.Source>
                            </Image>
                            <Label Grid.Column="1" Text="Rating" Style="{StaticResource Caption1}" TextColor="{StaticResource Gray400}" VerticalTextAlignment="Center" />
                            <Label Grid.Column="2" Text="{Binding AdultDisplay}" Style="{StaticResource Caption1Strong}" VerticalTextAlignment="Center" />
                        </Grid>

                    </VerticalStackLayout>

                    <!-- Trailer + AniList link (inline) -->
                    <Grid ColumnDefinitions="Auto,*,Auto">
                        <!-- Trailer button (left) -->
                        <Border Grid.Column="0" StrokeShape="RoundRectangle 12" StrokeThickness="1" Stroke="{StaticResource Gray600}"
                                Padding="12,8" BackgroundColor="Transparent"
                                IsVisible="{Binding HasTrailer}">
                            <Border.GestureRecognizers>
                                <TapGestureRecognizer Command="{Binding OpenUrlCommand}" CommandParameter="{Binding TrailerUrl}" />
                            </Border.GestureRecognizers>
                            <HorizontalStackLayout Spacing="8">
                                <Image WidthRequest="16" HeightRequest="16" VerticalOptions="Center">
                                    <Image.Source>
                                        <FontImageSource Glyph="{x:Static icons:FluentIconsRegular.Play24}"
                                                         FontFamily="{x:Static icons:FluentIconsRegular.FontFamily}"
                                                         Color="{Binding Converter={StaticResource RainbowAccentConverter}, ConverterParameter='Trailer'}"
                                                         Size="16" />
                                    </Image.Source>
                                </Image>
                                <Label Text="Watch Trailer" Style="{StaticResource Caption1Strong}"
                                       TextColor="{Binding Converter={StaticResource RainbowAccentConverter}, ConverterParameter='Trailer'}"
                                       VerticalTextAlignment="Center" />
                            </HorizontalStackLayout>
                        </Border>
                        <!-- AniList link (right) -->
                        <Border Grid.Column="2" StrokeShape="RoundRectangle 12" StrokeThickness="1" Stroke="{StaticResource Gray600}"
                                Padding="12,8" BackgroundColor="Transparent"
                                IsVisible="{Binding Media.SiteUrl, Converter={StaticResource StringNotNullOrEmptyConverter}}">
                            <Border.GestureRecognizers>
                                <TapGestureRecognizer Command="{Binding OpenUrlCommand}" CommandParameter="{Binding Media.SiteUrl}" />
                            </Border.GestureRecognizers>
                            <HorizontalStackLayout Spacing="8">
                                <Image WidthRequest="16" HeightRequest="16" VerticalOptions="Center">
                                    <Image.Source>
                                        <FontImageSource Glyph="{x:Static icons:FluentIconsRegular.Globe24}"
                                                         FontFamily="{x:Static icons:FluentIconsRegular.FontFamily}"
                                                         Color="{StaticResource Gray400}"
                                                         Size="16" />
                                    </Image.Source>
                                </Image>
                                <Label Text="View on AniList" Style="{StaticResource Caption1Strong}"
                                       TextColor="{StaticResource Gray400}"
                                       VerticalTextAlignment="Center" />
                            </HorizontalStackLayout>
                        </Border>
                    </Grid>
                </VerticalStackLayout>
            </Border>

            <!-- ============================================ -->
            <!-- 7. RELATIONS -->
            <!-- ============================================ -->
            <VerticalStackLayout Spacing="10" IsVisible="{Binding HasRelations}">
                <Border Style="{StaticResource SectionHeaderStyle}"
                        Background="{Binding Converter={StaticResource RainbowAccentConverter}, ConverterParameter='RelationsHeader'}">
                    <HorizontalStackLayout Spacing="8">
                        <Image WidthRequest="20" HeightRequest="20" VerticalOptions="Center">
                            <Image.Source>
                                <FontImageSource Glyph="{x:Static icons:FluentIconsRegular.Link24}"
                                                 FontFamily="{x:Static icons:FluentIconsRegular.FontFamily}"
                                                 Color="{AppThemeBinding Light=Black, Dark=White}"
                                                 Size="20" />
                            </Image.Source>
                        </Image>
                        <Label Text="Relations" Style="{StaticResource Title3}" TextColor="{AppThemeBinding Light=Black, Dark=White}" />
                    </HorizontalStackLayout>
                </Border>
                <ScrollView Orientation="Horizontal">
                    <HorizontalStackLayout Spacing="10"
                                           BindableLayout.ItemsSource="{Binding Relations}">
                        <BindableLayout.ItemTemplate>
                            <DataTemplate x:DataType="models:MediaRelationEdge">
                                <Border Style="{StaticResource CardStyle}" Padding="0" WidthRequest="130">
                                    <Border.GestureRecognizers>
                                        <TapGestureRecognizer x:DataType="{x:Null}"
                                                              Command="{Binding Source={x:Reference RootView}, Path=BindingContext.NavigateToMediaCommand}"
                                                              CommandParameter="{Binding Node.Id}" />
                                    </Border.GestureRecognizers>
                                    <VerticalStackLayout>
                                        <Image Source="{Binding Node.CoverImage.Large}"
                                               Aspect="AspectFill"
                                               HeightRequest="170"
                                               WidthRequest="130">
                                            <Image.Clip>
                                                <RoundRectangleGeometry Rect="0,0,130,170" CornerRadius="16,16,0,0" />
                                            </Image.Clip>
                                        </Image>
                                        <VerticalStackLayout Padding="8,6,8,8" Spacing="2">
                                            <Label Text="{Binding RelationType}"
                                                   Style="{StaticResource Caption2}"
                                                   TextColor="{Binding RelationType, Converter={StaticResource RainbowAccentConverter}}"
                                                   FontAttributes="Bold" />
                                            <Label Text="{Binding Node.DisplayTitle}"
                                                   Style="{StaticResource Caption1}"
                                                   MaxLines="2"
                                                   LineBreakMode="TailTruncation" />
                                        </VerticalStackLayout>
                                    </VerticalStackLayout>
                                </Border>
                            </DataTemplate>
                        </BindableLayout.ItemTemplate>
                    </HorizontalStackLayout>
                </ScrollView>
            </VerticalStackLayout>

            <!-- ============================================ -->
            <!-- 7. CHARACTERS -->
            <!-- ============================================ -->
            <VerticalStackLayout Spacing="10" IsVisible="{Binding HasCharacters}">
                <Border Style="{StaticResource SectionHeaderStyle}"
                        Background="{Binding Converter={StaticResource RainbowAccentConverter}, ConverterParameter='CharactersHeader'}">
                    <HorizontalStackLayout Spacing="8">
                        <Image WidthRequest="20" HeightRequest="20" VerticalOptions="Center">
                            <Image.Source>
                                <FontImageSource Glyph="{x:Static icons:FluentIconsRegular.People24}"
                                                 FontFamily="{x:Static icons:FluentIconsRegular.FontFamily}"
                                                 Color="{AppThemeBinding Light=Black, Dark=White}"
                                                 Size="20" />
                            </Image.Source>
                        </Image>
                        <Label Text="Characters" Style="{StaticResource Title3}" TextColor="{AppThemeBinding Light=Black, Dark=White}" />
                    </HorizontalStackLayout>
                </Border>
                <ScrollView Orientation="Horizontal">
                    <HorizontalStackLayout Spacing="10"
                                           BindableLayout.ItemsSource="{Binding Characters}">
                        <BindableLayout.ItemTemplate>
                            <DataTemplate x:DataType="models:CharacterEdge">
                                <Border Style="{StaticResource CardStyle}" Padding="0" WidthRequest="110">
                                    <VerticalStackLayout>
                                        <Image Source="{Binding Node.Image.Large}"
                                               Aspect="AspectFill"
                                               HeightRequest="140"
                                               WidthRequest="110">
                                            <Image.Clip>
                                                <RoundRectangleGeometry Rect="0,0,110,140" CornerRadius="16,16,0,0" />
                                            </Image.Clip>
                                        </Image>
                                        <VerticalStackLayout Padding="8,6,8,8" Spacing="2">
                                            <Label Text="{Binding Node.Name.Full}"
                                                   Style="{StaticResource Caption1}"
                                                   MaxLines="2"
                                                   LineBreakMode="TailTruncation" />
                                            <Label Text="{Binding Role}"
                                                   Style="{StaticResource Caption2}"
                                                   TextColor="{Binding Role, Converter={StaticResource RainbowAccentConverter}}"
                                                   FontAttributes="Bold" />
                                        </VerticalStackLayout>
                                    </VerticalStackLayout>
                                </Border>
                            </DataTemplate>
                        </BindableLayout.ItemTemplate>
                    </HorizontalStackLayout>
                </ScrollView>
            </VerticalStackLayout>

            <!-- ============================================ -->
            <!-- TAGS -->
            <!-- ============================================ -->
            <VerticalStackLayout Spacing="10" IsVisible="{Binding HasTags}">
                <Border Style="{StaticResource SectionHeaderStyle}"
                        Background="{Binding Converter={StaticResource RainbowAccentConverter}, ConverterParameter='TagsHeader'}">
                    <HorizontalStackLayout Spacing="8">
                        <Image WidthRequest="20" HeightRequest="20" VerticalOptions="Center">
                            <Image.Source>
                                <FontImageSource Glyph="{x:Static icons:FluentIconsRegular.Tag24}"
                                                 FontFamily="{x:Static icons:FluentIconsRegular.FontFamily}"
                                                 Color="{AppThemeBinding Light=Black, Dark=White}"
                                                 Size="20" />
                            </Image.Source>
                        </Image>
                        <Label Text="Tags" Style="{StaticResource Title3}" TextColor="{AppThemeBinding Light=Black, Dark=White}" />
                    </HorizontalStackLayout>
                </Border>
                <Border Style="{StaticResource CardStyle}" Padding="12">
                    <VerticalStackLayout Spacing="6"
                                         BindableLayout.ItemsSource="{Binding Tags}">
                        <BindableLayout.ItemTemplate>
                            <DataTemplate x:DataType="models:MediaTag">
                                <Grid ColumnDefinitions="*,80,40" ColumnSpacing="8" Padding="0,4">
                                    <Label Grid.Column="0" Text="{Binding Name}" Style="{StaticResource Caption1}"
                                           MaxLines="1" LineBreakMode="TailTruncation" VerticalTextAlignment="Center" />
                                    <BoxView Grid.Column="1" HeightRequest="6"
                                             WidthRequest="{Binding BarWidth}"
                                             CornerRadius="3"
                                             Color="{Binding Name, Converter={StaticResource RainbowAccentConverter}}"
                                             BackgroundColor="Transparent"
                                             HorizontalOptions="Start" VerticalOptions="Center" />
                                    <Label Grid.Column="2" Text="{Binding Rank, StringFormat='{0}%'}"
                                           Style="{StaticResource Caption2}"
                                           TextColor="{Binding Name, Converter={StaticResource RainbowAccentConverter}}"
                                           HorizontalTextAlignment="End" VerticalTextAlignment="Center" />
                                </Grid>
                            </DataTemplate>
                        </BindableLayout.ItemTemplate>
                    </VerticalStackLayout>
                </Border>
            </VerticalStackLayout>

            <!-- ============================================ -->
            <!-- 10. STATS -->
            <!-- ============================================ -->
            <VerticalStackLayout Spacing="10" IsVisible="{Binding HasStats}">
                <Border Style="{StaticResource SectionHeaderStyle}"
                        Background="{Binding Converter={StaticResource RainbowAccentConverter}, ConverterParameter='StatsHeader'}">
                    <HorizontalStackLayout Spacing="8">
                        <Image WidthRequest="20" HeightRequest="20" VerticalOptions="Center">
                            <Image.Source>
                                <FontImageSource Glyph="{x:Static icons:FluentIconsRegular.DataBarVertical24}"
                                                 FontFamily="{x:Static icons:FluentIconsRegular.FontFamily}"
                                                 Color="{AppThemeBinding Light=Black, Dark=White}"
                                                 Size="20" />
                            </Image.Source>
                        </Image>
                        <Label Text="Stats" Style="{StaticResource Title3}" TextColor="{AppThemeBinding Light=Black, Dark=White}" />
                    </HorizontalStackLayout>
                </Border>
                <Border Style="{StaticResource CardStyle}" Padding="16">
                    <VerticalStackLayout Spacing="16">
                        <!-- Score Distribution Bar Chart -->
                        <VerticalStackLayout Spacing="4">
                            <Label Text="Score Distribution" Style="{StaticResource Caption1Strong}" TextColor="{StaticResource Gray400}" />
                            <HorizontalStackLayout Spacing="6" HorizontalOptions="Center" HeightRequest="120"
                                                   BindableLayout.ItemsSource="{Binding ScoreDistribution}">
                                <BindableLayout.ItemTemplate>
                                    <DataTemplate x:DataType="models:ScoreDistributionItem">
                                        <Grid WidthRequest="24" RowDefinitions="*,Auto" RowSpacing="2">
                                            <BoxView Grid.Row="0"
                                                     HeightRequest="{Binding BarHeight}"
                                                     WidthRequest="20"
                                                     CornerRadius="3"
                                                     Color="{Binding Score, Converter={StaticResource RainbowAccentConverter}}"
                                                     BackgroundColor="Transparent"
                                                     VerticalOptions="End"
                                                     HorizontalOptions="Center" />
                                            <Label Grid.Row="1"
                                                   Text="{Binding Score}"
                                                   Style="{StaticResource Caption2}"
                                                   TextColor="{StaticResource Gray400}"
                                                   HorizontalTextAlignment="Center"
                                                   FontSize="9" />
                                        </Grid>
                                    </DataTemplate>
                                </BindableLayout.ItemTemplate>
                            </HorizontalStackLayout>
                        </VerticalStackLayout>
                        <!-- Status Distribution Pills -->
                        <VerticalStackLayout Spacing="4">
                            <Label Text="Status Distribution" Style="{StaticResource Caption1Strong}" TextColor="{StaticResource Gray400}" />
                            <FlexLayout Wrap="Wrap" JustifyContent="Start" AlignItems="Center"
                                        BindableLayout.ItemsSource="{Binding StatusDistribution}">
                                <BindableLayout.ItemTemplate>
                                    <DataTemplate x:DataType="models:StatusDistribution">
                                        <Border Style="{StaticResource ChipBorderStyle}" Padding="10,6" Margin="0,0,6,6">
                                            <HorizontalStackLayout Spacing="6">
                                                <Label Text="{Binding StatusDisplay}" Style="{StaticResource ChipLabelStyle}"
                                                       TextColor="{Binding Status, Converter={StaticResource RainbowAccentConverter}}" />
                                                <Label Text="{Binding Amount}" Style="{StaticResource Caption2}"
                                                       TextColor="{StaticResource Gray400}" VerticalTextAlignment="Center" />
                                            </HorizontalStackLayout>
                                        </Border>
                                    </DataTemplate>
                                </BindableLayout.ItemTemplate>
                            </FlexLayout>
                        </VerticalStackLayout>
                    </VerticalStackLayout>
                </Border>
            </VerticalStackLayout>

            <!-- ============================================ -->
            <!-- 11. RECOMMENDATIONS -->
            <!-- ============================================ -->
            <VerticalStackLayout Spacing="10" IsVisible="{Binding HasRecommendations}">
                <Border Style="{StaticResource SectionHeaderStyle}"
                        Background="{Binding Converter={StaticResource RainbowAccentConverter}, ConverterParameter='RecsHeader'}">
                    <HorizontalStackLayout Spacing="8">
                        <Image WidthRequest="20" HeightRequest="20" VerticalOptions="Center">
                            <Image.Source>
                                <FontImageSource Glyph="{x:Static icons:FluentIconsRegular.Sparkle24}"
                                                 FontFamily="{x:Static icons:FluentIconsRegular.FontFamily}"
                                                 Color="{AppThemeBinding Light=Black, Dark=White}"
                                                 Size="20" />
                            </Image.Source>
                        </Image>
                        <Label Text="Recommendations" Style="{StaticResource Title3}" TextColor="{AppThemeBinding Light=Black, Dark=White}" />
                    </HorizontalStackLayout>
                </Border>
                <ScrollView Orientation="Horizontal">
                    <HorizontalStackLayout Spacing="10"
                                           BindableLayout.ItemsSource="{Binding Recommendations}">
                        <BindableLayout.ItemTemplate>
                            <DataTemplate x:DataType="models:MediaRecommendationNode">
                                <Border Style="{StaticResource CardStyle}" Padding="0" WidthRequest="130">
                                    <Border.GestureRecognizers>
                                        <TapGestureRecognizer x:DataType="{x:Null}"
                                                              Command="{Binding Source={x:Reference RootView}, Path=BindingContext.NavigateToMediaCommand}"
                                                              CommandParameter="{Binding MediaRecommendation.Id}" />
                                    </Border.GestureRecognizers>
                                    <VerticalStackLayout>
                                        <Image Source="{Binding MediaRecommendation.CoverImage.Large}"
                                               Aspect="AspectFill"
                                               HeightRequest="170"
                                               WidthRequest="130">
                                            <Image.Clip>
                                                <RoundRectangleGeometry Rect="0,0,130,170" CornerRadius="16,16,0,0" />
                                            </Image.Clip>
                                        </Image>
                                        <VerticalStackLayout Padding="8,6,8,8" Spacing="2">
                                            <Label Text="{Binding MediaRecommendation.DisplayTitle}"
                                                   Style="{StaticResource Caption1}"
                                                   MaxLines="2"
                                                   LineBreakMode="TailTruncation" />
                                        </VerticalStackLayout>
                                    </VerticalStackLayout>
                                </Border>
                            </DataTemplate>
                        </BindableLayout.ItemTemplate>
                    </HorizontalStackLayout>
                </ScrollView>
            </VerticalStackLayout>

            <!-- ============================================ -->
            <!-- 12. STAFF -->
            <!-- ============================================ -->
            <VerticalStackLayout Spacing="10" IsVisible="{Binding HasStaff}">
                <Border Style="{StaticResource SectionHeaderStyle}"
                        Background="{Binding Converter={StaticResource RainbowAccentConverter}, ConverterParameter='StaffHeader'}">
                    <HorizontalStackLayout Spacing="8">
                        <Image WidthRequest="20" HeightRequest="20" VerticalOptions="Center">
                            <Image.Source>
                                <FontImageSource Glyph="{x:Static icons:FluentIconsRegular.Person24}"
                                                 FontFamily="{x:Static icons:FluentIconsRegular.FontFamily}"
                                                 Color="{AppThemeBinding Light=Black, Dark=White}"
                                                 Size="20" />
                            </Image.Source>
                        </Image>
                        <Label Text="Staff" Style="{StaticResource Title3}" TextColor="{AppThemeBinding Light=Black, Dark=White}" />
                    </HorizontalStackLayout>
                </Border>
                <ScrollView Orientation="Horizontal">
                    <HorizontalStackLayout Spacing="10"
                                           BindableLayout.ItemsSource="{Binding Staff}">
                        <BindableLayout.ItemTemplate>
                            <DataTemplate x:DataType="models:StaffEdge">
                                <Border Style="{StaticResource CardStyle}" Padding="0" WidthRequest="110">
                                    <VerticalStackLayout>
                                        <Grid HeightRequest="140" WidthRequest="110">
                                            <!-- Person silhouette placeholder (underneath, always rendered) -->
                                            <Border BackgroundColor="{AppThemeBinding Light={StaticResource Gray200}, Dark={StaticResource Gray900}}"
                                                    StrokeThickness="0" Padding="0"
                                                    StrokeShape="RoundRectangle 16,16,0,0">
                                                <Image HorizontalOptions="Center" VerticalOptions="Center"
                                                       WidthRequest="40" HeightRequest="40">
                                                    <Image.Source>
                                                        <FontImageSource Glyph="{x:Static icons:FluentIconsRegular.Person48}"
                                                                         FontFamily="{x:Static icons:FluentIconsRegular.FontFamily}"
                                                                         Color="{StaticResource Gray500}" Size="40" />
                                                    </Image.Source>
                                                </Image>
                                            </Border>
                                            <!-- Actual staff image (covers placeholder when URL exists) -->
                                            <Image Source="{Binding Node.Image.Medium}"
                                                   Aspect="AspectFill"
                                                   HeightRequest="140"
                                                   WidthRequest="110"
                                                   IsVisible="{Binding Node.Image.Medium, Converter={StaticResource StringNotNullOrEmptyConverter}}">
                                                <Image.Clip>
                                                    <RoundRectangleGeometry Rect="0,0,110,140" CornerRadius="16,16,0,0" />
                                                </Image.Clip>
                                            </Image>
                                        </Grid>
                                        <VerticalStackLayout Padding="8,6,8,8" Spacing="2">
                                            <Label Text="{Binding Node.Name.Full}"
                                                   Style="{StaticResource Caption1}"
                                                   MaxLines="2"
                                                   LineBreakMode="TailTruncation" />
                                            <Label Text="{Binding Role}"
                                                   Style="{StaticResource Caption2}"
                                                   TextColor="{Binding Role, Converter={StaticResource RainbowAccentConverter}}"
                                                   FontAttributes="Bold" />
                                        </VerticalStackLayout>
                                    </VerticalStackLayout>
                                </Border>
                            </DataTemplate>
                        </BindableLayout.ItemTemplate>
                    </HorizontalStackLayout>
                </ScrollView>
            </VerticalStackLayout>

            <!-- ============================================ -->
            <!-- 14. EXTERNAL LINKS -->
            <!-- ============================================ -->
            <VerticalStackLayout Spacing="10" IsVisible="{Binding HasExternalLinks}">
                <Border Style="{StaticResource SectionHeaderStyle}"
                        Background="{Binding Converter={StaticResource RainbowAccentConverter}, ConverterParameter='LinksHeader'}">
                    <HorizontalStackLayout Spacing="8">
                        <Image WidthRequest="20" HeightRequest="20" VerticalOptions="Center">
                            <Image.Source>
                                <FontImageSource Glyph="{x:Static icons:FluentIconsRegular.Globe24}"
                                                 FontFamily="{x:Static icons:FluentIconsRegular.FontFamily}"
                                                 Color="{AppThemeBinding Light=Black, Dark=White}"
                                                 Size="20" />
                            </Image.Source>
                        </Image>
                        <Label Text="External Links" Style="{StaticResource Title3}" TextColor="{AppThemeBinding Light=Black, Dark=White}" />
                    </HorizontalStackLayout>
                </Border>
                <FlexLayout Wrap="Wrap" JustifyContent="Start" AlignItems="Center"
                            BindableLayout.ItemsSource="{Binding ExternalLinks}">
                    <BindableLayout.ItemTemplate>
                        <DataTemplate x:DataType="models:MediaExternalLink">
                            <Border Style="{StaticResource ChipBorderStyle}" Padding="10,6" Margin="0,0,6,6">
                                <Border.GestureRecognizers>
                                    <TapGestureRecognizer x:DataType="{x:Null}"
                                                          Command="{Binding Source={x:Reference RootView}, Path=BindingContext.OpenUrlCommand}"
                                                          CommandParameter="{Binding Url}" />
                                </Border.GestureRecognizers>
                                <Label Text="{Binding Site}" Style="{StaticResource ChipLabelStyle}"
                                       TextColor="{Binding Site, Converter={StaticResource RainbowAccentConverter}}" />
                            </Border>
                        </DataTemplate>
                    </BindableLayout.ItemTemplate>
                </FlexLayout>
            </VerticalStackLayout>

            <!-- ============================================ -->
            <!-- BOTTOM SPACER -->
            <!-- ============================================ -->
            <ContentView HeightRequest="24" />

        </VerticalStackLayout>
    </ScrollView>
</ContentView>
