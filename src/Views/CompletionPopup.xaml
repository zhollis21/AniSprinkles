<?xml version="1.0" encoding="utf-8" ?>
<toolkit:Popup xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
               xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
               xmlns:toolkit="http://schemas.microsoft.com/dotnet/2022/maui/toolkit"
               xmlns:icons="clr-namespace:IconFont.Maui.FluentIcons;assembly=IconFont.Maui.FluentIcons"
               xmlns:converters="clr-namespace:AniSprinkles.Converters"
               x:Class="AniSprinkles.Views.CompletionPopup"
               x:TypeArguments="x:Boolean"
               BackgroundColor="Transparent">

    <toolkit:Popup.Resources>
        <converters:RainbowAccentConverter x:Key="RainbowAccentConverter" />
    </toolkit:Popup.Resources>

    <Border StrokeShape="RoundRectangle 20"
            StrokeThickness="0"
            Padding="24,20,24,20"
            WidthRequest="320"
            Background="{AppThemeBinding Light={StaticResource LightSecondaryBackground},
                                         Dark={StaticResource DarkSecondaryBackground}}">
        <VerticalStackLayout Spacing="16">

            <!-- Completion icon -->
            <Image WidthRequest="40" HeightRequest="40" HorizontalOptions="Center">
                <Image.Source>
                    <FontImageSource Glyph="{x:Static icons:FluentIconsRegular.CheckmarkCircle24}"
                                     FontFamily="{x:Static icons:FluentIconsRegular.FontFamily}"
                                     Color="{StaticResource RainbowGreen}" Size="40" />
                </Image.Source>
            </Image>

            <!-- Title -->
            <Label Text="All episodes watched!"
                   Style="{StaticResource Title3}"
                   HorizontalTextAlignment="Center" />

            <!-- Description -->
            <Label x:Name="DescriptionLabel"
                   Style="{StaticResource Body2}"
                   TextColor="{StaticResource Gray400}"
                   HorizontalTextAlignment="Center"
                   MaxLines="3"
                   LineBreakMode="TailTruncation" />

            <!-- Action buttons -->
            <Grid ColumnDefinitions="*,10,*">
                <Button Grid.Column="0" Text="No"
                        BackgroundColor="Transparent"
                        TextColor="{StaticResource RainbowRed}"
                        BorderColor="{StaticResource RainbowRed}"
                        Opacity="0.85"
                        BorderWidth="1"
                        CornerRadius="8"
                        HeightRequest="24"
                        FontSize="16"
                        FontAttributes="Bold"
                        Padding="0"
                        Margin="10,20,10,10"
                        ContentLayout="Left,4"
                        Clicked="OnNoClicked">
                    <Button.ImageSource>
                        <FontImageSource Glyph="{x:Static icons:FluentIconsRegular.Dismiss24}"
                                         FontFamily="{x:Static icons:FluentIconsRegular.FontFamily}"
                                         Color="{StaticResource RainbowRed}" Size="18" />
                    </Button.ImageSource>
                </Button>
                <Button Grid.Column="2" Text="Yes"
                        BackgroundColor="Transparent"
                        TextColor="{StaticResource RainbowGreen}"
                        BorderColor="{StaticResource RainbowGreen}"
                        CornerRadius="8"
                        HeightRequest="24"
                        FontSize="16"
                        FontAttributes="Bold"
                        Padding="0"
                        Margin="10,20,10,10"
                        ContentLayout="Left,4"
                        Clicked="OnYesClicked">
                    <Button.ImageSource>
                        <FontImageSource Glyph="{x:Static icons:FluentIconsRegular.Checkmark24}"
                                         FontFamily="{x:Static icons:FluentIconsRegular.FontFamily}"
                                         Color="{StaticResource RainbowGreen}" Size="18" />
                    </Button.ImageSource>
                </Button>
            </Grid>

        </VerticalStackLayout>
    </Border>

</toolkit:Popup>
