<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:pageModels="clr-namespace:AniSprinkles.PageModels"
             x:Class="AniSprinkles.Pages.MediaDetailsPage"
             x:DataType="pageModels:MediaDetailsPageModel"
             Title="{Binding PageTitle}"
             Shell.TitleColor="{Binding PageTitle, Converter={StaticResource RainbowAccentConverter}}">

    <Grid Padding="24" RowDefinitions="Auto,Auto,*" RowSpacing="12">
        <HorizontalStackLayout Spacing="12">
            <Label Text="{Binding StatusMessage}"
                   IsVisible="{Binding HasStatusMessage}"
                   FontSize="12"
                   TextColor="{StaticResource Gray400}" />
            <Button Text="Details"
                    Command="{Binding ToggleDetailsCommand}"
                    IsVisible="{Binding HasErrorDetails}" />
        </HorizontalStackLayout>

        <VerticalStackLayout Grid.Row="1"
                             Spacing="8"
                             IsVisible="{Binding IsErrorDetailsVisible}">
            <ScrollView HeightRequest="160">
                <Label Text="{Binding ErrorDetails}"
                       FontSize="12"
                       LineBreakMode="WordWrap"
                       TextColor="{StaticResource Gray400}" />
            </ScrollView>
            <HorizontalStackLayout Spacing="12">
                <Button Text="Copy" Command="{Binding CopyErrorCommand}" />
                <Button Text="Share" Command="{Binding ShareErrorCommand}" />
            </HorizontalStackLayout>
        </VerticalStackLayout>

        <Grid Grid.Row="2">
            <ContentView x:Name="LoadedContentHost" />

            <VerticalStackLayout Spacing="8"
                                 HorizontalOptions="Center"
                                 VerticalOptions="Center"
                                 IsVisible="{Binding IsInitialLoading}">
                <ActivityIndicator IsRunning="{Binding IsInitialLoading}"
                                   IsVisible="{Binding IsInitialLoading}" />
                <Label Text="Loading details..."
                       FontSize="12"
                       TextColor="{StaticResource Gray400}" />
            </VerticalStackLayout>
        </Grid>
    </Grid>
</ContentPage>
