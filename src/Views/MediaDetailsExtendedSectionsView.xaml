<?xml version="1.0" encoding="utf-8" ?>
<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:models="clr-namespace:AniSprinkles.Models"
             xmlns:pageModels="clr-namespace:AniSprinkles.PageModels"
             x:Class="AniSprinkles.Views.MediaDetailsExtendedSectionsView"
             x:DataType="pageModels:MediaDetailsPageModel">
    <VerticalStackLayout Spacing="16">
        <VerticalStackLayout Spacing="8"
                             IsVisible="{Binding HasGenres}">
            <Label Text="Genres"
                   FontSize="16"
                   FontAttributes="Bold" />
            <FlexLayout Wrap="Wrap"
                        BindableLayout.ItemsSource="{Binding Genres}">
                <BindableLayout.ItemTemplate>
                    <DataTemplate>
                        <Border Padding="6,4"
                                Margin="0,0,8,8"
                                Stroke="{StaticResource Gray500}"
                                StrokeThickness="1">
                            <Label Text="{Binding .}"
                                   FontSize="12"
                                   TextColor="{StaticResource Gray300}" />
                        </Border>
                    </DataTemplate>
                </BindableLayout.ItemTemplate>
            </FlexLayout>
        </VerticalStackLayout>

        <VerticalStackLayout Spacing="8"
                             IsVisible="{Binding HasSynonyms}">
            <Label Text="Synonyms"
                   FontSize="16"
                   FontAttributes="Bold" />
            <VerticalStackLayout BindableLayout.ItemsSource="{Binding Synonyms}"
                                 Spacing="2">
                <BindableLayout.ItemTemplate>
                    <DataTemplate>
                        <Label Text="{Binding .}"
                               FontSize="12"
                               TextColor="{StaticResource Gray400}" />
                    </DataTemplate>
                </BindableLayout.ItemTemplate>
            </VerticalStackLayout>
        </VerticalStackLayout>

        <VerticalStackLayout Spacing="8"
                             IsVisible="{Binding HasStudios}">
            <Label Text="Studios"
                   FontSize="16"
                   FontAttributes="Bold" />
            <VerticalStackLayout BindableLayout.ItemsSource="{Binding Studios}"
                                 Spacing="2">
                <BindableLayout.ItemTemplate>
                    <DataTemplate x:DataType="models:Studio">
                        <VerticalStackLayout Padding="0,2" Spacing="2">
                            <Label Text="{Binding Name}"
                                   FontSize="12"
                                   TextColor="{StaticResource Gray400}" />
                            <Label Text="Animation Studio"
                                   FontSize="11"
                                   TextColor="{StaticResource Gray500}"
                                   IsVisible="{Binding IsAnimationStudio}" />
                        </VerticalStackLayout>
                    </DataTemplate>
                </BindableLayout.ItemTemplate>
            </VerticalStackLayout>
        </VerticalStackLayout>

        <VerticalStackLayout Spacing="8"
                             IsVisible="{Binding HasTags}">
            <Label Text="Top Tags"
                   FontSize="16"
                   FontAttributes="Bold" />
            <VerticalStackLayout BindableLayout.ItemsSource="{Binding Tags}"
                                 Spacing="2">
                <BindableLayout.ItemTemplate>
                    <DataTemplate x:DataType="models:MediaTag">
                        <Grid ColumnDefinitions="*,Auto"
                              ColumnSpacing="10"
                              Padding="0,4">
                            <Label Text="{Binding Name}"
                                   FontSize="12"
                                   TextColor="{StaticResource Gray300}" />
                            <Label Grid.Column="1"
                                   Text="{Binding Rank, StringFormat='Rank {0}'}"
                                   FontSize="12"
                                   TextColor="{StaticResource Gray500}" />
                        </Grid>
                    </DataTemplate>
                </BindableLayout.ItemTemplate>
            </VerticalStackLayout>
        </VerticalStackLayout>

        <VerticalStackLayout Spacing="8"
                             IsVisible="{Binding HasRankings}">
            <Label Text="Rankings"
                   FontSize="16"
                   FontAttributes="Bold" />
            <VerticalStackLayout BindableLayout.ItemsSource="{Binding Rankings}"
                                 Spacing="2">
                <BindableLayout.ItemTemplate>
                    <DataTemplate x:DataType="models:MediaRanking">
                        <Grid ColumnDefinitions="Auto,*"
                              ColumnSpacing="10"
                              Padding="0,4">
                            <Label Text="{Binding Rank, StringFormat='#{0}'}"
                                   FontSize="12"
                                   FontAttributes="Bold" />
                            <Label Grid.Column="1"
                                   FontSize="12"
                                   TextColor="{StaticResource Gray400}">
                                <Label.FormattedText>
                                    <FormattedString>
                                        <Span Text="{Binding Context}" />
                                        <Span Text=" - " />
                                        <Span Text="{Binding Type}" />
                                        <Span Text=" " />
                                        <Span Text="{Binding Year}" />
                                    </FormattedString>
                                </Label.FormattedText>
                            </Label>
                        </Grid>
                    </DataTemplate>
                </BindableLayout.ItemTemplate>
            </VerticalStackLayout>
        </VerticalStackLayout>

        <VerticalStackLayout Spacing="8"
                             IsVisible="{Binding HasExternalLinks}">
            <Label Text="Links"
                   FontSize="16"
                   FontAttributes="Bold" />
            <VerticalStackLayout BindableLayout.ItemsSource="{Binding ExternalLinks}"
                                 Spacing="2">
                <BindableLayout.ItemTemplate>
                    <DataTemplate x:DataType="models:MediaExternalLink">
                        <Grid ColumnDefinitions="*,Auto"
                              ColumnSpacing="10"
                              Padding="0,4">
                            <VerticalStackLayout Grid.Column="0" Spacing="2">
                                <Label Text="{Binding Site}"
                                       FontSize="12"
                                       FontAttributes="Bold" />
                                <Label Text="{Binding Url}"
                                       FontSize="11"
                                       LineBreakMode="TailTruncation"
                                       TextColor="{StaticResource Gray500}" />
                            </VerticalStackLayout>
                            <Label Grid.Column="1"
                                   Text="Open"
                                   FontSize="12"
                                   TextColor="{StaticResource Primary}"
                                   VerticalTextAlignment="Center">
                                <Label.GestureRecognizers>
                                    <TapGestureRecognizer Command="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.OpenUrlCommand}"
                                                          CommandParameter="{Binding Url}" />
                                </Label.GestureRecognizers>
                            </Label>
                        </Grid>
                    </DataTemplate>
                </BindableLayout.ItemTemplate>
            </VerticalStackLayout>
        </VerticalStackLayout>

        <VerticalStackLayout Spacing="8"
                             IsVisible="{Binding HasStreamingEpisodes}">
            <Label Text="Streaming Episodes"
                   FontSize="16"
                   FontAttributes="Bold" />
            <VerticalStackLayout BindableLayout.ItemsSource="{Binding StreamingEpisodes}"
                                 Spacing="2">
                <BindableLayout.ItemTemplate>
                    <DataTemplate x:DataType="models:MediaStreamingEpisode">
                        <Grid ColumnDefinitions="*,Auto"
                              ColumnSpacing="10"
                              Padding="0,4">
                            <VerticalStackLayout Grid.Column="0" Spacing="2">
                                <Label Text="{Binding Title}"
                                       FontSize="12"
                                       TextColor="{StaticResource Gray300}" />
                                <Label Text="{Binding Site}"
                                       FontSize="11"
                                       TextColor="{StaticResource Gray500}" />
                            </VerticalStackLayout>
                            <Label Grid.Column="1"
                                   Text="Open"
                                   FontSize="12"
                                   TextColor="{StaticResource Primary}"
                                   VerticalTextAlignment="Center">
                                <Label.GestureRecognizers>
                                    <TapGestureRecognizer Command="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.OpenUrlCommand}"
                                                          CommandParameter="{Binding Url}" />
                                </Label.GestureRecognizers>
                            </Label>
                        </Grid>
                    </DataTemplate>
                </BindableLayout.ItemTemplate>
            </VerticalStackLayout>
        </VerticalStackLayout>

        <VerticalStackLayout Spacing="8"
                             IsVisible="{Binding HasTrailer}">
            <Label Text="Trailer"
                   FontSize="16"
                   FontAttributes="Bold" />
            <Label Text="{Binding TrailerUrl}"
                   FontSize="12"
                   TextColor="{StaticResource Gray400}" />
            <Button Text="Open Trailer"
                    Command="{Binding OpenUrlCommand}"
                    CommandParameter="{Binding TrailerUrl}" />
        </VerticalStackLayout>

        <VerticalStackLayout Spacing="8"
                             IsVisible="{Binding Media.SiteUrl, Converter={StaticResource StringNotNullOrEmptyConverter}}">
            <Label Text="AniList Page"
                   FontSize="16"
                   FontAttributes="Bold" />
            <Label Text="{Binding Media.SiteUrl}"
                   FontSize="12"
                   TextColor="{StaticResource Gray400}" />
            <Button Text="Open AniList"
                    Command="{Binding OpenUrlCommand}"
                    CommandParameter="{Binding Media.SiteUrl}" />
        </VerticalStackLayout>

        <Label Text="Description"
               FontSize="16"
               FontAttributes="Bold"
               IsVisible="{Binding Media.Description, Converter={StaticResource StringNotNullOrEmptyConverter}}" />
        <Label Text="{Binding Media.Description}"
               TextType="Html"
               FontSize="12"
               TextColor="{StaticResource Gray400}"
               IsVisible="{Binding Media.Description, Converter={StaticResource StringNotNullOrEmptyConverter}}" />
    </VerticalStackLayout>
</ContentView>
