<?xml version="1.0" encoding="utf-8" ?>
<toolkit:Popup xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
               xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
               xmlns:toolkit="http://schemas.microsoft.com/dotnet/2022/maui/toolkit"
               xmlns:icons="clr-namespace:IconFont.Maui.FluentIcons;assembly=IconFont.Maui.FluentIcons"
               x:Class="AniSprinkles.Views.ConfirmPopup"
               x:TypeArguments="x:Boolean"
               BackgroundColor="Transparent">

    <Border StrokeShape="RoundRectangle 20"
            StrokeThickness="0"
            Padding="24,20,24,20"
            WidthRequest="320"
            Background="{StaticResource SecondaryBackground}">
        <VerticalStackLayout Spacing="16">

            <!-- Optional icon (visibility toggled in code-behind) -->
            <Image x:Name="IconImage"
                   WidthRequest="40" HeightRequest="40"
                   HorizontalOptions="Center"
                   IsVisible="False">
                <Image.Source>
                    <FontImageSource x:Name="IconSource"
                                     FontFamily="{x:Static icons:FluentIconsRegular.FontFamily}"
                                     Size="40" />
                </Image.Source>
            </Image>

            <!-- Title -->
            <Label x:Name="TitleLabel"
                   Style="{StaticResource Title3}"
                   HorizontalTextAlignment="Center" />

            <!-- Message -->
            <Label x:Name="MessageLabel"
                   Style="{StaticResource Body2}"
                   TextColor="{StaticResource Gray400}"
                   HorizontalTextAlignment="Center" />

            <!-- Action buttons -->
            <Grid ColumnDefinitions="*,10,*">
                <Button x:Name="CancelButton" Grid.Column="0"
                        BackgroundColor="Transparent"
                        TextColor="{StaticResource Gray400}"
                        BorderColor="{StaticResource Gray500}"
                        BorderWidth="1"
                        CornerRadius="8"
                        HeightRequest="24"
                        FontSize="16"
                        FontAttributes="Bold"
                        Padding="0"
                        Margin="10,20,10,10"
                        ContentLayout="Left,4"
                        Clicked="OnCancelClicked" />
                <Button x:Name="ConfirmButton" Grid.Column="2"
                        BackgroundColor="Transparent"
                        CornerRadius="8"
                        HeightRequest="24"
                        FontSize="16"
                        FontAttributes="Bold"
                        Padding="0"
                        Margin="10,20,10,10"
                        ContentLayout="Left,4"
                        Clicked="OnConfirmClicked" />
            </Grid>

        </VerticalStackLayout>
    </Border>

</toolkit:Popup>
