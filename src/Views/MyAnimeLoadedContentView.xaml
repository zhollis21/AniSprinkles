<?xml version="1.0" encoding="utf-8" ?>
<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:pageModels="clr-namespace:AniSprinkles.PageModels"
             xmlns:models="clr-namespace:AniSprinkles.Models"
             xmlns:f="clr-namespace:AniSprinkles.Resources.Fonts"
             x:Class="AniSprinkles.Views.MyAnimeLoadedContentView"
             x:DataType="pageModels:MyAnimePageModel">
	<Grid RowDefinitions="Auto,Auto,*" RowSpacing="8">

		<ActivityIndicator IsRunning="{Binding IsNavigatingToDetails}"
				   IsVisible="{Binding IsNavigatingToDetails}"
				   VerticalOptions="Center" HorizontalOptions="Center" Opacity="0.8" />

	</Grid>
</ContentView>
