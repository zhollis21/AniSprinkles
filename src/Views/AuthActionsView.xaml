<?xml version="1.0" encoding="utf-8" ?>
<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="AniSprinkles.Views.AuthActionsView"
             x:DataType="{x:Null}">
    <HorizontalStackLayout Spacing="12">
        <Button Text="Sign In"
                Command="{Binding SignInCommand}"
                Background="{Binding IsAuthenticated, Converter={StaticResource RainbowAccentConverter}, ConverterParameter=true}"
                IsVisible="{Binding IsAuthenticated, Converter={StaticResource InvertedBoolConverter}}" />
        <Button Text="Sign Out"
                Command="{Binding SignOutCommand}"
                Background="{Binding IsAuthenticated, Converter={StaticResource RainbowAccentConverter}, ConverterParameter=true}"
                IsVisible="{Binding IsAuthenticated}" />
    </HorizontalStackLayout>
</ContentView>
