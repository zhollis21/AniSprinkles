<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:pageModels="clr-namespace:AniSprinkles.PageModels"
             xmlns:models="clr-namespace:AniSprinkles.Models"
             xmlns:views="clr-namespace:AniSprinkles.Views"
             xmlns:f="clr-namespace:AniSprinkles.Resources.Fonts"
             x:Class="AniSprinkles.Pages.MyAnimePage"
             x:DataType="pageModels:MyAnimePageModel"
             x:Name="MyAnimePageRoot"
             Title="{Binding Title}"
             Shell.TitleColor="{Binding Title, Converter={StaticResource RainbowAccentConverter}}">

    <Grid Padding="{StaticResource LayoutPadding}"
          RowDefinitions="Auto,Auto,Auto,*"
          RowSpacing="8">

        <!-- Row 0: Status/Error/Sign-in (consolidated) -->
        <VerticalStackLayout Grid.Row="0" Spacing="8">
            <!-- Status + Details -->
            <HorizontalStackLayout Spacing="12">
                <Label Text="{Binding StatusMessage}"
                       IsVisible="{Binding HasStatusMessage}"
                       Style="{StaticResource Caption1}"
                       TextColor="{StaticResource Gray400}" />

                <Button Text="Details"
                        Command="{Binding ToggleDetailsCommand}"
                        IsVisible="{Binding HasErrorDetails}" />
            </HorizontalStackLayout>

            <!-- Error details -->
            <VerticalStackLayout Spacing="8"
                                 IsVisible="{Binding IsErrorDetailsVisible}">

                <Border Style="{StaticResource CardStyle}"
                        Padding="12">
                    <ScrollView HeightRequest="160">
                        <Label Text="{Binding ErrorDetails}"
                               Style="{StaticResource Caption1}"
                               LineBreakMode="WordWrap"
                               TextColor="{StaticResource Gray400}" />
                    </ScrollView>
                </Border>

                <HorizontalStackLayout Spacing="12">
                    <Button Text="Copy" Command="{Binding CopyErrorCommand}" />
                    <Button Text="Share" Command="{Binding ShareErrorCommand}" />
                </HorizontalStackLayout>
            </VerticalStackLayout>

            <!-- Sign in prompt -->
            <VerticalStackLayout Spacing="8"
                                 IsVisible="{Binding IsAuthenticated, Converter={StaticResource InvertedBoolConverter}}">

                <Label Text="Sign in to AniList to view and update your anime lists:"
                       Style="{StaticResource Caption1}"
                       TextColor="{StaticResource Gray400}"
                       IsVisible="{Binding IsAuthenticationPending, Converter={StaticResource InvertedBoolConverter}}" />

                <views:AuthActionsView IsVisible="{Binding IsAuthenticationPending, Converter={StaticResource InvertedBoolConverter}}" />
            </VerticalStackLayout>
        </VerticalStackLayout>

        <!-- Row 1: Sort + Filter toolbar -->
        <Grid Grid.Row="1"
              ColumnDefinitions="*,Auto"
              ColumnSpacing="8"
              Margin="0,-4,0,-4"
              IsVisible="{Binding IsAuthenticated}">

            <!-- Sort chips -->
            <HorizontalStackLayout Spacing="6">
                <Label Text="Sort:"
                       Style="{StaticResource Caption1}"
                       TextColor="{StaticResource Gray400}"
                       VerticalOptions="Center" />

                <Border Style="{StaticResource ChipBorderStyle}"
                        Padding="10,6"
                        Opacity="{Binding CurrentSortField, Converter={StaticResource SortFieldOpacityConverter}, ConverterParameter=LastUpdated}">
                    <Border.GestureRecognizers>
                        <TapGestureRecognizer Command="{Binding SetSortFieldCommand}" CommandParameter="LastUpdated" />
                    </Border.GestureRecognizers>
                    <Label Text="Updated"
                           FontSize="12"
                           FontAttributes="Bold"
                           VerticalTextAlignment="Center"
                           HorizontalTextAlignment="Center"
                           TextColor="{Binding Converter={StaticResource RainbowAccentConverter}, ConverterParameter='Updated'}" />
                </Border>

                <Border Style="{StaticResource ChipBorderStyle}"
                        Padding="10,6"
                        Opacity="{Binding CurrentSortField, Converter={StaticResource SortFieldOpacityConverter}, ConverterParameter=Title}">
                    <Border.GestureRecognizers>
                        <TapGestureRecognizer Command="{Binding SetSortFieldCommand}" CommandParameter="Title" />
                    </Border.GestureRecognizers>
                    <Label Text="Title"
                           FontSize="12"
                           FontAttributes="Bold"
                           VerticalTextAlignment="Center"
                           HorizontalTextAlignment="Center"
                           TextColor="{Binding Converter={StaticResource RainbowAccentConverter}, ConverterParameter='Title'}" />
                </Border>

                <Border Style="{StaticResource ChipBorderStyle}"
                        Padding="10,6"
                        Opacity="{Binding CurrentSortField, Converter={StaticResource SortFieldOpacityConverter}, ConverterParameter=Score}">
                    <Border.GestureRecognizers>
                        <TapGestureRecognizer Command="{Binding SetSortFieldCommand}" CommandParameter="Score" />
                    </Border.GestureRecognizers>
                    <Label Text="Score"
                           FontSize="12"
                           FontAttributes="Bold"
                           VerticalTextAlignment="Center"
                           HorizontalTextAlignment="Center"
                           TextColor="{Binding Converter={StaticResource RainbowAccentConverter}, ConverterParameter='Score'}" />
                </Border>

                <Border Style="{StaticResource ChipBorderStyle}"
                        Padding="10,6"
                        Opacity="{Binding CurrentSortField, Converter={StaticResource SortFieldOpacityConverter}, ConverterParameter=Progress}">
                    <Border.GestureRecognizers>
                        <TapGestureRecognizer Command="{Binding SetSortFieldCommand}" CommandParameter="Progress" />
                    </Border.GestureRecognizers>
                    <Label Text="Progress"
                           FontSize="12"
                           FontAttributes="Bold"
                           VerticalTextAlignment="Center"
                           HorizontalTextAlignment="Center"
                           TextColor="{Binding Converter={StaticResource RainbowAccentConverter}, ConverterParameter='Progress'}" />
                </Border>

                <!-- Sort direction toggle -->
                <Label Text="{Binding SortDirectionIcon}"
                       FontSize="20"
                       FontAttributes="Bold"
                       Padding="8,0"
                       VerticalOptions="Center"
                       TextColor="{AppThemeBinding Light={StaticResource RainbowBlue}, Dark={StaticResource RainbowCyan}}">
                    <Label.GestureRecognizers>
                        <TapGestureRecognizer Command="{Binding ToggleSortDirectionCommand}" />
                    </Label.GestureRecognizers>
                </Label>
            </HorizontalStackLayout>

            <!-- Search toggle button -->
            <ImageButton Grid.Column="1"
                         WidthRequest="36"
                         HeightRequest="36"
                         Padding="6"
                         VerticalOptions="Center"
                         BackgroundColor="Transparent"
                         Command="{Binding ToggleFilterBarCommand}">
                <ImageButton.Source>
                    <FontImageSource Glyph="{x:Static f:FluentUI.search_20_regular}"
                                     FontFamily="{x:Static f:FluentUI.FontFamily}"
                                     Color="{AppThemeBinding Light={StaticResource DarkOnLightBackground}, Dark={StaticResource LightOnDarkBackground}}"
                                     Size="20" />
                </ImageButton.Source>
            </ImageButton>
        </Grid>

        <!-- Row 2: Search bar (expandable) -->
        <Border Grid.Row="2"
                Style="{StaticResource CardStyle}"
                Padding="8,4"
                IsVisible="{Binding IsFilterBarVisible}">
            <Grid ColumnDefinitions="Auto,*,Auto"
                  ColumnSpacing="8">
                <Image VerticalOptions="Center">
                    <Image.Source>
                        <FontImageSource Glyph="{x:Static f:FluentUI.search_20_regular}"
                                         FontFamily="{x:Static f:FluentUI.FontFamily}"
                                         Color="{StaticResource Gray400}"
                                         Size="18" />
                    </Image.Source>
                </Image>

                <Entry Grid.Column="1"
                       Placeholder="Search titles..."
                       Text="{Binding SearchText}"
                       ClearButtonVisibility="Never"
                       BackgroundColor="Transparent"
                       FontSize="15"
                       VerticalOptions="Center" />

                <ImageButton Grid.Column="2"
                             WidthRequest="28"
                             HeightRequest="28"
                             Padding="4"
                             VerticalOptions="Center"
                             BackgroundColor="Transparent"
                             Command="{Binding ClearSearchCommand}"
                             IsVisible="{Binding HasSearchText}">
                    <ImageButton.Source>
                        <FontImageSource Glyph="{x:Static f:FluentUI.dismiss_circle_20_regular}"
                                         FontFamily="{x:Static f:FluentUI.FontFamily}"
                                         Color="{StaticResource Gray400}"
                                         Size="18" />
                    </ImageButton.Source>
                </ImageButton>
            </Grid>
        </Border>

        <!-- Row 3: Main content — CollectionView in * row for proper virtualization -->
        <Grid Grid.Row="3">

            <CollectionView ItemsSource="{Binding Sections}"
                            IsGrouped="True"
                            SelectionMode="Single"
                            SelectionChanged="OnSelectionChanged"
                            IsVisible="{Binding IsAuthenticated}">
                <CollectionView.ItemsLayout>
                    <LinearItemsLayout Orientation="Vertical" ItemSpacing="8" />
                </CollectionView.ItemsLayout>

                <!-- Group header -->
                <CollectionView.GroupHeaderTemplate>
                    <DataTemplate x:DataType="pageModels:MediaListSection">
                        <Border Style="{StaticResource SectionHeaderStyle}"
                                Background="{Binding Title, Converter={StaticResource RainbowAccentConverter}, ConverterParameter=true}">
                            <Grid ColumnDefinitions="Auto,*,Auto"
                                  ColumnSpacing="12"
                                  VerticalOptions="Center">

                                <Grid.GestureRecognizers>
                                    <TapGestureRecognizer Command="{Binding ToggleCommand}" />
                                </Grid.GestureRecognizers>

                                <!-- Chevron Icon -->
                                <Image Source="{StaticResource IconChevronRight}"
                                       WidthRequest="{StaticResource size200}"
                                       HeightRequest="{StaticResource size200}"
                                       VerticalOptions="Center">
                                    <Image.Triggers>
                                        <DataTrigger TargetType="Image" Binding="{Binding IsExpanded}" Value="True">
                                            <Setter Property="Rotation" Value="90" />
                                        </DataTrigger>
                                    </Image.Triggers>
                                </Image>

                                <Label Grid.Column="1"
                                       Text="{Binding Title}"
                                       Style="{StaticResource Title3}"
                                       VerticalOptions="Center" />

                                <Border Grid.Column="2"
                                        Style="{StaticResource CountBadgeStyle}"
                                        VerticalOptions="Center">
                                    <Label Text="{Binding DisplayCount}"
                                           Style="{StaticResource Caption1Strong}"
                                           HorizontalTextAlignment="Center"
                                           VerticalTextAlignment="Center" />
                                </Border>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </CollectionView.GroupHeaderTemplate>

                <!-- Items -->
                <CollectionView.ItemTemplate>
                    <DataTemplate x:DataType="models:MediaListEntry">
                        <Border Style="{StaticResource ListRowStyle}"
                                HeightRequest="72">
                            <Grid ColumnDefinitions="4,*,Auto"
                                  RowDefinitions="Auto,Auto"
                                  ColumnSpacing="12"
                                  RowSpacing="6"
                                  Padding="12">

                                <!-- Accent strip -->
                                <BoxView Grid.RowSpan="2"
                                         BackgroundColor="{Binding StatusDisplay, Converter={StaticResource RainbowAccentConverter}}"
                                         WidthRequest="4"
                                         CornerRadius="2"
                                         VerticalOptions="Fill" />

                                <Label Grid.Column="1"
                                       Text="{Binding Media.DisplayTitle}"
                                       Style="{StaticResource Body1Strong}"
                                       LineBreakMode="TailTruncation" />

                                <Label Grid.Column="2"
                                       Text="{Binding StatusDisplay}"
                                       Style="{StaticResource Caption1}"
                                       HorizontalOptions="End"
                                       TextColor="{StaticResource Gray400}" />

                                <Label Grid.Row="1" Grid.Column="1"
                                       Text="{Binding ProgressDisplay}"
                                       Style="{StaticResource Caption1}"
                                       TextColor="{StaticResource Gray400}" />

                                <Label Grid.Row="1" Grid.Column="2"
                                       Text="{Binding ScoreDisplay, StringFormat='Score: {0}'}"
                                       Style="{StaticResource Caption1}"
                                       HorizontalOptions="End"
                                       TextColor="{StaticResource Gray400}" />
                            </Grid>
                        </Border>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>

            <!-- Auth pending overlay -->
            <VerticalStackLayout Spacing="8"
                                 HorizontalOptions="Center"
                                 VerticalOptions="Center"
                                 IsVisible="{Binding IsAuthenticationPending}">
                <ActivityIndicator IsRunning="True"
                                   IsVisible="True" />
                <Label Text="Checking authentication..."
                       Style="{StaticResource Caption1}"
                       TextColor="{StaticResource Gray400}" />
            </VerticalStackLayout>

            <!-- Initial loading overlay -->
            <VerticalStackLayout Spacing="8"
                                 HorizontalOptions="Center"
                                 VerticalOptions="Center"
                                 IsVisible="{Binding IsInitialLoading}">
                <ActivityIndicator IsRunning="{Binding IsInitialLoading}"
                                   IsVisible="{Binding IsInitialLoading}" />
                <Label Text="Loading anime list..."
                       Style="{StaticResource Caption1}"
                       TextColor="{StaticResource Gray400}" />
            </VerticalStackLayout>

            <!-- Navigating overlay spinner -->
            <ActivityIndicator IsRunning="{Binding IsNavigatingToDetails}"
                               IsVisible="{Binding IsNavigatingToDetails}"
                               VerticalOptions="Center"
                               HorizontalOptions="Center"
                               Opacity="0.8" />
        </Grid>
    </Grid>
</ContentPage>
