<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:pageModels="clr-namespace:AniSprinkles.PageModels"
             xmlns:models="clr-namespace:AniSprinkles.Models"
             xmlns:views="clr-namespace:AniSprinkles.Views"
             x:Class="AniSprinkles.Pages.MyAnimePage"
             x:DataType="pageModels:MyAnimePageModel"
             Title="{Binding Title}">

    <Grid Padding="24" RowDefinitions="Auto,Auto,Auto,Auto,*" RowSpacing="12">
        <Label Text="My Anime"
               FontSize="28"
               FontAttributes="Bold"
               VerticalOptions="Center" />

        <HorizontalStackLayout Grid.Row="1" Spacing="12">
            <ActivityIndicator IsRunning="{Binding IsBusy}" IsVisible="{Binding IsBusy}" />
            <Label Text="{Binding StatusMessage}"
                   IsVisible="{Binding HasStatusMessage}"
                   FontSize="12"
                   TextColor="{StaticResource Gray400}" />
            <Button Text="Details"
                    Command="{Binding ToggleDetailsCommand}"
                    IsVisible="{Binding HasErrorDetails}" />
        </HorizontalStackLayout>

        <VerticalStackLayout Grid.Row="2"
                             Spacing="8"
                             IsVisible="{Binding IsErrorDetailsVisible}">
            <ScrollView HeightRequest="160">
                <Label Text="{Binding ErrorDetails}"
                       FontSize="12"
                       LineBreakMode="WordWrap"
                       TextColor="{StaticResource Gray400}" />
            </ScrollView>
            <HorizontalStackLayout Spacing="12">
                <Button Text="Copy" Command="{Binding CopyErrorCommand}" />
                <Button Text="Share" Command="{Binding ShareErrorCommand}" />
            </HorizontalStackLayout>
        </VerticalStackLayout>

        <VerticalStackLayout Grid.Row="3"
                             Spacing="8"
                             IsVisible="{Binding IsAuthenticated, Converter={StaticResource InvertedBoolConverter}}">
            <Label Text="Sign in to AniList to view and update your anime lists:"
                   FontSize="12"
                   TextColor="{StaticResource Gray400}" />
            <views:AuthActionsView />
        </VerticalStackLayout>

        <CollectionView Grid.Row="4"
                        ItemsSource="{Binding Sections}"
                        IsGrouped="True"
                        ItemSizingStrategy="MeasureFirstItem"
                        SelectionMode="None"
                        IsVisible="{Binding IsAuthenticated}">
            <CollectionView.GroupHeaderTemplate>
                <DataTemplate x:DataType="pageModels:MediaListSection">
                    <Grid Padding="8" ColumnDefinitions="Auto,*,Auto" ColumnSpacing="10">
                        <Grid.GestureRecognizers>
                            <TapGestureRecognizer Command="{Binding ToggleCommand}" />
                        </Grid.GestureRecognizers>

                        <Label Text=">"
                               FontSize="14"
                               FontAttributes="Bold"
                               VerticalOptions="Center"
                               TextColor="{StaticResource Gray400}">
                            <Label.Triggers>
                                <DataTrigger TargetType="Label" Binding="{Binding IsExpanded}" Value="True">
                                    <Setter Property="Rotation" Value="90" />
                                </DataTrigger>
                            </Label.Triggers>
                        </Label>
                        <Label Grid.Column="1"
                               Text="{Binding Title}"
                               FontAttributes="Bold"
                               VerticalOptions="Center" />
                        <Label Grid.Column="2"
                               Text="{Binding TotalCount, StringFormat='({0})'}"
                               TextColor="{StaticResource Gray400}"
                               VerticalOptions="Center" />
                    </Grid>
                </DataTemplate>
            </CollectionView.GroupHeaderTemplate>
            <CollectionView.ItemTemplate>
                <DataTemplate x:DataType="models:MediaListEntry">
                    <Grid Padding="12" RowSpacing="6">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <Label Grid.Row="0" Grid.Column="0"
                               Text="{Binding Media.DisplayTitle}"
                               FontSize="16"
                               LineBreakMode="TailTruncation" />
                        <Label Grid.Row="0" Grid.Column="1"
                               Text="{Binding StatusDisplay}"
                               FontSize="12"
                               HorizontalOptions="End" />

                        <Label Grid.Row="1" Grid.Column="0"
                               Text="{Binding ProgressDisplay}"
                               FontSize="12"
                               TextColor="{StaticResource Gray400}" />
                        <Label Grid.Row="1" Grid.Column="1"
                               Text="{Binding ScoreDisplay, StringFormat='Score: {0}'}"
                               FontSize="12"
                               HorizontalOptions="End"
                               TextColor="{StaticResource Gray400}" />
                    </Grid>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>
    </Grid>
</ContentPage>
