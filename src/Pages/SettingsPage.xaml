<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:pageModels="clr-namespace:AniSprinkles.PageModels"
             xmlns:views="clr-namespace:AniSprinkles.Views"
             x:Class="AniSprinkles.Pages.SettingsPage"
             x:DataType="pageModels:SettingsPageModel"
             Title="Settings">

    <VerticalStackLayout Padding="24" Spacing="16">
        <Label Text="Settings" FontSize="28" FontAttributes="Bold" />

        <Label Text="Account" FontSize="16" FontAttributes="Bold" />
        <Label Text="{Binding StatusMessage}"
               FontSize="12"
               TextColor="{StaticResource Gray400}"
               IsVisible="{Binding HasStatusMessage}" />
        <views:AuthActionsView />

        <Label Text="AniList User ID" FontSize="16" FontAttributes="Bold" Margin="0,12,0,0"
               IsVisible="{Binding AniListUserId, Converter={StaticResource StringNotNullOrEmptyConverter}}" />
        <Label Text="{Binding AniListUserId}"
               FontSize="14"
               TextColor="{Binding AniListUserId, Converter={StaticResource RainbowAccentConverter}}"
               IsVisible="{Binding AniListUserId, Converter={StaticResource StringNotNullOrEmptyConverter}}" />
    </VerticalStackLayout>
</ContentPage>
