<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:pageModels="clr-namespace:AniSprinkles.PageModels"
             xmlns:views="clr-namespace:AniSprinkles.Views"
             xmlns:toolkit="http://schemas.microsoft.com/dotnet/2022/maui/toolkit"
             x:Class="AniSprinkles.Pages.MediaDetailsPage"
             x:DataType="pageModels:MediaDetailsPageModel"
             Title="{Binding PageTitle}"
             Shell.TitleColor="{Binding PageTitle, Converter={StaticResource RainbowAccentConverter}}">

    <!--
        CurrentStateKey returns null for Content (default child) and the enum
        name for InitialLoading / Error. See MediaDetailsPageModel.CurrentState.
        Outer grid reserves a row for the global outage banner.
    -->
    <Grid RowDefinitions="Auto,*">
        <views:OutageBanner Grid.Row="0" Margin="24,12,24,0" />
        <Grid Grid.Row="1"
              Padding="24"
              toolkit:StateContainer.CurrentState="{Binding CurrentStateKey}">
        <toolkit:StateContainer.StateViews>
            <!-- InitialLoading: centered spinner -->
            <VerticalStackLayout toolkit:StateView.StateKey="InitialLoading"
                                 Spacing="8"
                                 HorizontalOptions="Center"
                                 VerticalOptions="Center">
                <ActivityIndicator IsRunning="True" IsVisible="True" />
                <Label Text="Loading details..."
                       FontSize="12"
                       TextColor="{StaticResource Gray400}" />
            </VerticalStackLayout>

            <!-- Error: full-page error view -->
            <ScrollView toolkit:StateView.StateKey="Error"
                        VerticalOptions="Center">
                <views:ErrorStateView ErrorTitle="{Binding ErrorTitle}"
                                      ErrorSubtitle="{Binding ErrorSubtitle}"
                                      ErrorIconGlyph="{Binding ErrorIconGlyph}"
                                      ErrorAccentColor="{StaticResource RainbowOrange}"
                                      RetryCommand="{Binding RetryLoadCommand}"
                                      ShowRetryButton="{Binding CanRetry}"
                                      ErrorDetails="{Binding ErrorDetails}" />
            </ScrollView>
        </toolkit:StateContainer.StateViews>

            <!-- Default content (CurrentState = Content): loaded content host -->
            <ContentView x:Name="LoadedContentHost" />
        </Grid>
    </Grid>
</ContentPage>
