<?xml version="1.0" encoding="utf-8" ?>
<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:pageModels="clr-namespace:AniSprinkles.PageModels"
             xmlns:models="clr-namespace:AniSprinkles.Models"
             xmlns:f="clr-namespace:AniSprinkles.Resources.Fonts"
             x:Class="AniSprinkles.Views.MediaDetailsLoadedContentView"
             x:DataType="pageModels:MediaDetailsPageModel">

    <ScrollView>
        <VerticalStackLayout Padding="{StaticResource LayoutPadding}" Spacing="16">

            <!-- ============================================ -->
            <!-- 1. HERO: Banner + Cover + Title -->
            <!-- ============================================ -->
            <Border Style="{StaticResource CardStyle}" Padding="0">
                <Grid RowDefinitions="200,*">
                    <!-- Banner image -->
                    <Image Grid.Row="0"
                           Source="{Binding BannerImageUrl}"
                           Aspect="AspectFill"
                           IsVisible="{Binding HasBannerImage}">
                        <Image.Clip>
                            <RoundRectangleGeometry Rect="0,0,800,200" CornerRadius="16,16,0,0" />
                        </Image.Clip>
                    </Image>
                    <!-- Fallback colour block when no banner -->
                    <BoxView Grid.Row="0"
                             BackgroundColor="{Binding PageTitle, Converter={StaticResource RainbowAccentConverter}}"
                             Opacity="0.25"
                             IsVisible="{Binding HasBannerImage, Converter={StaticResource InvertedBoolConverter}}" />
                    <!-- Gradient overlay for readability -->
                    <BoxView Grid.Row="0">
                        <BoxView.Background>
                            <LinearGradientBrush StartPoint="0,0.4" EndPoint="0,1">
                                <GradientStop Color="Transparent" Offset="0" />
                                <GradientStop Color="#CC000000" Offset="1" />
                            </LinearGradientBrush>
                        </BoxView.Background>
                    </BoxView>

                    <!-- Cover + Title overlay -->
                    <Grid Grid.Row="0" Grid.RowSpan="2"
                          ColumnDefinitions="120,*"
                          ColumnSpacing="14"
                          VerticalOptions="End"
                          Padding="16,0,16,16">
                        <!-- Cover poster -->
                        <Border Grid.Column="0"
                                WidthRequest="120" HeightRequest="170"
                                StrokeShape="RoundRectangle 10"
                                StrokeThickness="2"
                                Stroke="{AppThemeBinding Light={StaticResource LightSecondaryBackground}, Dark={StaticResource DarkSecondaryBackground}}"
                                Padding="0"
                                Margin="0,60,0,0">
                            <Image Source="{Binding CoverImageUrl}"
                                   Aspect="AspectFill"
                                   WidthRequest="120"
                                   HeightRequest="170" />
                        </Border>
                        <!-- Title stack -->
                        <VerticalStackLayout Grid.Column="1" Spacing="6" VerticalOptions="End">
                            <Label Text="{Binding Media.DisplayTitle}"
                                   Style="{StaticResource Title1}"
                                   TextColor="{Binding PageTitle, Converter={StaticResource RainbowAccentConverter}}"
                                   MaxLines="3"
                                   LineBreakMode="TailTruncation">
                                <Label.Shadow>
                                    <Shadow Brush="Black" Offset="0,0" Radius="8" Opacity="0.9" />
                                </Label.Shadow>
                            </Label>
                            <HorizontalStackLayout Spacing="8">
                                <Label Text="{Binding FormatDisplay}"
                                       Style="{StaticResource Caption1Strong}"
                                       TextColor="{StaticResource Gray400}">
                                    <Label.Shadow><Shadow Brush="Black" Offset="0,0" Radius="6" Opacity="0.8" /></Label.Shadow>
                                </Label>
                                <Label Text="|" Style="{StaticResource Caption1}" TextColor="{StaticResource Gray400}">
                                    <Label.Shadow><Shadow Brush="Black" Offset="0,0" Radius="6" Opacity="0.8" /></Label.Shadow>
                                </Label>
                                <Label Text="{Binding StatusFormatted}"
                                       Style="{StaticResource Caption1Strong}"
                                       TextColor="{StaticResource Gray400}">
                                    <Label.Shadow><Shadow Brush="Black" Offset="0,0" Radius="6" Opacity="0.8" /></Label.Shadow>
                                </Label>
                            </HorizontalStackLayout>
                        </VerticalStackLayout>
                    </Grid>
                </Grid>
            </Border>

            <!-- ============================================ -->
            <!-- 2. STAT PILLS: Score, Popularity, Favourites -->
            <!-- ============================================ -->
            <Grid ColumnDefinitions="*,*,*" ColumnSpacing="10">
                <!-- Score pill -->
                <Border Grid.Column="0" Style="{StaticResource CardStyle}" Padding="10,10">
                    <VerticalStackLayout Spacing="2" HorizontalOptions="Center">
                        <Image WidthRequest="18" HeightRequest="18" HorizontalOptions="Center">
                            <Image.Source>
                                <FontImageSource Glyph="{x:Static f:FluentUI.star_24_regular}"
                                                 FontFamily="{x:Static f:FluentUI.FontFamily}"
                                                 Color="{Binding Converter={StaticResource RainbowAccentConverter}, ConverterParameter='Score'}"
                                                 Size="18" />
                            </Image.Source>
                        </Image>
                        <Label Text="{Binding ScorePercentDisplay}" Style="{StaticResource Title2}" HorizontalTextAlignment="Center"
                               TextColor="{Binding Converter={StaticResource RainbowAccentConverter}, ConverterParameter='Score'}" />
                        <Label Text="Score" Style="{StaticResource Caption2}" TextColor="{StaticResource Gray400}" HorizontalTextAlignment="Center" />
                    </VerticalStackLayout>
                </Border>
                <!-- Popularity pill -->
                <Border Grid.Column="1" Style="{StaticResource CardStyle}" Padding="10,10">
                    <VerticalStackLayout Spacing="2" HorizontalOptions="Center">
                        <Image WidthRequest="18" HeightRequest="18" HorizontalOptions="Center">
                            <Image.Source>
                                <FontImageSource Glyph="{x:Static f:FluentUI.people_24_regular}"
                                                 FontFamily="{x:Static f:FluentUI.FontFamily}"
                                                 Color="{Binding Converter={StaticResource RainbowAccentConverter}, ConverterParameter='Popularity'}"
                                                 Size="18" />
                            </Image.Source>
                        </Image>
                        <Label Text="{Binding PopularityDisplay}" Style="{StaticResource Title2}" HorizontalTextAlignment="Center"
                               TextColor="{Binding Converter={StaticResource RainbowAccentConverter}, ConverterParameter='Popularity'}" />
                        <Label Text="Popularity" Style="{StaticResource Caption2}" TextColor="{StaticResource Gray400}" HorizontalTextAlignment="Center" />
                    </VerticalStackLayout>
                </Border>
                <!-- Favourites pill -->
                <Border Grid.Column="2" Style="{StaticResource CardStyle}" Padding="10,10">
                    <VerticalStackLayout Spacing="2" HorizontalOptions="Center">
                        <Image WidthRequest="18" HeightRequest="18" HorizontalOptions="Center">
                            <Image.Source>
                                <FontImageSource Glyph="{x:Static f:FluentUI.heart_24_regular}"
                                                 FontFamily="{x:Static f:FluentUI.FontFamily}"
                                                 Color="{Binding Converter={StaticResource RainbowAccentConverter}, ConverterParameter='Favourites'}"
                                                 Size="18" />
                            </Image.Source>
                        </Image>
                        <Label Text="{Binding FavouritesDisplay}" Style="{StaticResource Title2}" HorizontalTextAlignment="Center"
                               TextColor="{Binding Converter={StaticResource RainbowAccentConverter}, ConverterParameter='Favourites'}" />
                        <Label Text="Favourites" Style="{StaticResource Caption2}" TextColor="{StaticResource Gray400}" HorizontalTextAlignment="Center" />
                    </VerticalStackLayout>
                </Border>
            </Grid>

            <!-- ============================================ -->
            <!-- 3. QUICK INFO CHIPS -->
            <!-- ============================================ -->
            <FlexLayout Wrap="Wrap" JustifyContent="Start" AlignItems="Center">
                <Border Style="{StaticResource ChipBorderStyle}" Padding="10,6" Margin="0,0,6,6"
                        IsVisible="{Binding EpisodesDisplay, Converter={StaticResource StringNotNullOrEmptyConverter}}">
                    <Label Text="{Binding EpisodesDisplay}" Style="{StaticResource ChipLabelStyle}"
                           TextColor="{Binding Converter={StaticResource RainbowAccentConverter}, ConverterParameter='Episodes'}" />
                </Border>
                <Border Style="{StaticResource ChipBorderStyle}" Padding="10,6" Margin="0,0,6,6"
                        IsVisible="{Binding DurationPillDisplay, Converter={StaticResource StringNotNullOrEmptyConverter}}">
                    <Label Text="{Binding DurationPillDisplay}" Style="{StaticResource ChipLabelStyle}"
                           TextColor="{Binding Converter={StaticResource RainbowAccentConverter}, ConverterParameter='Duration'}" />
                </Border>
                <Border Style="{StaticResource ChipBorderStyle}" Padding="10,6" Margin="0,0,6,6"
                        IsVisible="{Binding SeasonYearDisplay, Converter={StaticResource StringNotNullOrEmptyConverter}}">
                    <Label Text="{Binding SeasonYearDisplay}" Style="{StaticResource ChipLabelStyle}"
                           TextColor="{Binding Converter={StaticResource RainbowAccentConverter}, ConverterParameter='Season'}" />
                </Border>
                <Border Style="{StaticResource ChipBorderStyle}" Padding="10,6" Margin="0,0,6,6"
                        IsVisible="{Binding HasMainStudio}">
                    <Label Text="{Binding MainStudioName}" Style="{StaticResource ChipLabelStyle}"
                           TextColor="{Binding Converter={StaticResource RainbowAccentConverter}, ConverterParameter='Studio'}" />
                </Border>
                <Border Style="{StaticResource ChipBorderStyle}" Padding="10,6" Margin="0,0,6,6"
                        IsVisible="{Binding HasNextAiringInfo}">
                    <Label Text="{Binding NextAiringDisplay}" Style="{StaticResource ChipLabelStyle}"
                           TextColor="{Binding Converter={StaticResource RainbowAccentConverter}, ConverterParameter='Airing'}" />
                </Border>
            </FlexLayout>

            <!-- ============================================ -->
            <!-- 4. LIST STATUS SELECTOR -->
            <!-- ============================================ -->
            <VerticalStackLayout Spacing="8" IsVisible="{Binding IsAuthenticated}">
                <!-- Single card: header + inline expanding chips -->
                <Border Style="{StaticResource AccentCardBorderStyle}" Padding="14,12">
                    <VerticalStackLayout Spacing="12">
                        <!-- Tappable header row -->
                        <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="10">
                            <Grid.GestureRecognizers>
                                <TapGestureRecognizer Command="{Binding ToggleStatusExpandedCommand}" />
                            </Grid.GestureRecognizers>
                            <Image Grid.Column="0" WidthRequest="20" HeightRequest="20" VerticalOptions="Center">
                                <Image.Source>
                                    <FontImageSource Glyph="{x:Static f:FluentUI.ribbon_24_regular}"
                                                     FontFamily="{x:Static f:FluentUI.FontFamily}"
                                                     Color="{Binding ListStatusDisplay, Converter={StaticResource RainbowAccentConverter}}"
                                                     Size="20" />
                                </Image.Source>
                            </Image>
                            <Label Grid.Column="1" Text="{Binding ListStatusDisplay}"
                                   Style="{StaticResource Title3}"
                                   TextColor="{Binding ListStatusDisplay, Converter={StaticResource RainbowAccentConverter}}"
                                   VerticalTextAlignment="Center" />
                            <!-- Chevron down when collapsed -->
                            <Image Grid.Column="2" WidthRequest="16" HeightRequest="16" VerticalOptions="Center"
                                   IsVisible="{Binding IsStatusExpanded, Converter={StaticResource InvertedBoolConverter}}">
                                <Image.Source>
                                    <FontImageSource Glyph="{x:Static f:FluentUI.chevron_down_24_regular}"
                                                     FontFamily="{x:Static f:FluentUI.FontFamily}"
                                                     Color="{StaticResource Gray400}" Size="16" />
                                </Image.Source>
                            </Image>
                            <!-- Chevron up when expanded -->
                            <Image Grid.Column="2" WidthRequest="16" HeightRequest="16" VerticalOptions="Center"
                                   IsVisible="{Binding IsStatusExpanded}">
                                <Image.Source>
                                    <FontImageSource Glyph="{x:Static f:FluentUI.chevron_up_24_regular}"
                                                     FontFamily="{x:Static f:FluentUI.FontFamily}"
                                                     Color="{StaticResource Gray400}" Size="16" />
                                </Image.Source>
                            </Image>
                            <ActivityIndicator Grid.Column="2" IsRunning="{Binding IsSavingListEntry}" IsVisible="{Binding IsSavingListEntry}"
                                               WidthRequest="20" HeightRequest="20" VerticalOptions="Center" />
                        </Grid>

                        <!-- Inline status chips (expanded) -->
                        <FlexLayout Wrap="Wrap" JustifyContent="Start" AlignItems="Center"
                                    IsVisible="{Binding IsStatusExpanded}">
                            <Border Style="{StaticResource ChipBorderStyle}" Padding="10,6" Margin="0,0,6,6"
                                    Stroke="{Binding CurrentStatusKey, Converter={StaticResource SortFieldStrokeConverter}, ConverterParameter=Current}"
                                    Opacity="{Binding CurrentStatusKey, Converter={StaticResource SortFieldOpacityConverter}, ConverterParameter=Current}">
                                <Border.GestureRecognizers><TapGestureRecognizer Command="{Binding QuickSetStatusCommand}" CommandParameter="Current" /></Border.GestureRecognizers>
                                <Label Text="Watching" Style="{StaticResource ChipLabelStyle}" TextColor="{Binding Converter={StaticResource RainbowAccentConverter}, ConverterParameter='Current'}" />
                            </Border>
                            <Border Style="{StaticResource ChipBorderStyle}" Padding="10,6" Margin="0,0,6,6"
                                    Stroke="{Binding CurrentStatusKey, Converter={StaticResource SortFieldStrokeConverter}, ConverterParameter=Planning}"
                                    Opacity="{Binding CurrentStatusKey, Converter={StaticResource SortFieldOpacityConverter}, ConverterParameter=Planning}">
                                <Border.GestureRecognizers><TapGestureRecognizer Command="{Binding QuickSetStatusCommand}" CommandParameter="Planning" /></Border.GestureRecognizers>
                                <Label Text="Plan to Watch" Style="{StaticResource ChipLabelStyle}" TextColor="{Binding Converter={StaticResource RainbowAccentConverter}, ConverterParameter='Planning'}" />
                            </Border>
                            <Border Style="{StaticResource ChipBorderStyle}" Padding="10,6" Margin="0,0,6,6"
                                    Stroke="{Binding CurrentStatusKey, Converter={StaticResource SortFieldStrokeConverter}, ConverterParameter=Completed}"
                                    Opacity="{Binding CurrentStatusKey, Converter={StaticResource SortFieldOpacityConverter}, ConverterParameter=Completed}">
                                <Border.GestureRecognizers><TapGestureRecognizer Command="{Binding QuickSetStatusCommand}" CommandParameter="Completed" /></Border.GestureRecognizers>
                                <Label Text="Completed" Style="{StaticResource ChipLabelStyle}" TextColor="{Binding Converter={StaticResource RainbowAccentConverter}, ConverterParameter='Completed'}" />
                            </Border>
                            <Border Style="{StaticResource ChipBorderStyle}" Padding="10,6" Margin="0,0,6,6"
                                    Stroke="{Binding CurrentStatusKey, Converter={StaticResource SortFieldStrokeConverter}, ConverterParameter=Paused}"
                                    Opacity="{Binding CurrentStatusKey, Converter={StaticResource SortFieldOpacityConverter}, ConverterParameter=Paused}">
                                <Border.GestureRecognizers><TapGestureRecognizer Command="{Binding QuickSetStatusCommand}" CommandParameter="Paused" /></Border.GestureRecognizers>
                                <Label Text="Paused" Style="{StaticResource ChipLabelStyle}" TextColor="{Binding Converter={StaticResource RainbowAccentConverter}, ConverterParameter='Paused'}" />
                            </Border>
                            <Border Style="{StaticResource ChipBorderStyle}" Padding="10,6" Margin="0,0,6,6"
                                    Stroke="{Binding CurrentStatusKey, Converter={StaticResource SortFieldStrokeConverter}, ConverterParameter=Dropped}"
                                    Opacity="{Binding CurrentStatusKey, Converter={StaticResource SortFieldOpacityConverter}, ConverterParameter=Dropped}">
                                <Border.GestureRecognizers><TapGestureRecognizer Command="{Binding QuickSetStatusCommand}" CommandParameter="Dropped" /></Border.GestureRecognizers>
                                <Label Text="Dropped" Style="{StaticResource ChipLabelStyle}" TextColor="{Binding Converter={StaticResource RainbowAccentConverter}, ConverterParameter='Dropped'}" />
                            </Border>
                            <Border Style="{StaticResource ChipBorderStyle}" Padding="10,6" Margin="0,0,6,6"
                                    Stroke="{Binding CurrentStatusKey, Converter={StaticResource SortFieldStrokeConverter}, ConverterParameter=Repeating}"
                                    Opacity="{Binding CurrentStatusKey, Converter={StaticResource SortFieldOpacityConverter}, ConverterParameter=Repeating}">
                                <Border.GestureRecognizers><TapGestureRecognizer Command="{Binding QuickSetStatusCommand}" CommandParameter="Repeating" /></Border.GestureRecognizers>
                                <Label Text="Rewatching" Style="{StaticResource ChipLabelStyle}" TextColor="{Binding Converter={StaticResource RainbowAccentConverter}, ConverterParameter='Repeating'}" />
                            </Border>
                        </FlexLayout>
                    </VerticalStackLayout>
                </Border>

                <!-- Progress/Score row (when on list) -->
                <Grid ColumnDefinitions="*,*,Auto" ColumnSpacing="10"
                      IsVisible="{Binding HasListEntry}">
                    <Border Grid.Column="0" Style="{StaticResource CardStyle}" Padding="10,8">
                        <VerticalStackLayout Spacing="2" HorizontalOptions="Center">
                            <Label Text="Progress" Style="{StaticResource Caption2}" TextColor="{StaticResource Gray400}" HorizontalTextAlignment="Center" />
                            <Label Text="{Binding ListEntry.ProgressDisplay}" Style="{StaticResource Body1Strong}" HorizontalTextAlignment="Center" />
                        </VerticalStackLayout>
                    </Border>
                    <Border Grid.Column="1" Style="{StaticResource CardStyle}" Padding="10,8">
                        <VerticalStackLayout Spacing="2" HorizontalOptions="Center">
                            <Label Text="Score" Style="{StaticResource Caption2}" TextColor="{StaticResource Gray400}" HorizontalTextAlignment="Center" />
                            <Label Text="{Binding ListEntry.ScoreDisplay}" Style="{StaticResource Body1Strong}" HorizontalTextAlignment="Center" />
                        </VerticalStackLayout>
                    </Border>
                    <Border Grid.Column="2" Style="{StaticResource CardStyle}" Padding="10,8">
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer Command="{Binding EditListEntryCommand}" />
                        </Border.GestureRecognizers>
                        <Image WidthRequest="20" HeightRequest="20" VerticalOptions="Center">
                            <Image.Source>
                                <FontImageSource Glyph="{x:Static f:FluentUI.edit_24_regular}"
                                                 FontFamily="{x:Static f:FluentUI.FontFamily}"
                                                 Color="{Binding Converter={StaticResource RainbowAccentConverter}, ConverterParameter='Edit'}"
                                                 Size="20" />
                            </Image.Source>
                        </Image>
                    </Border>
                </Grid>

                <!-- Edit mode for progress/score -->
                <Border Style="{StaticResource CardStyle}" Padding="16"
                        IsVisible="{Binding IsEditingListEntry}">
                    <VerticalStackLayout Spacing="14">
                        <VerticalStackLayout Spacing="6">
                            <Label Text="Progress" Style="{StaticResource Caption1Strong}" />
                            <HorizontalStackLayout Spacing="10" VerticalOptions="Center">
                                <Border StrokeShape="RoundRectangle 8" StrokeThickness="1" Stroke="{StaticResource Gray600}"
                                        Padding="8,4" BackgroundColor="Transparent">
                                    <Border.GestureRecognizers><TapGestureRecognizer Command="{Binding DecrementProgressCommand}" /></Border.GestureRecognizers>
                                    <Image WidthRequest="16" HeightRequest="16">
                                        <Image.Source>
                                            <FontImageSource Glyph="{x:Static f:FluentUI.subtract_24_regular}"
                                                             FontFamily="{x:Static f:FluentUI.FontFamily}"
                                                             Color="{StaticResource Gray400}" Size="16" />
                                        </Image.Source>
                                    </Image>
                                </Border>
                                <Label Text="{Binding EditProgress}" Style="{StaticResource Body1Strong}" VerticalTextAlignment="Center" />
                                <Border StrokeShape="RoundRectangle 8" StrokeThickness="1" Stroke="{StaticResource Gray600}"
                                        Padding="8,4" BackgroundColor="Transparent">
                                    <Border.GestureRecognizers><TapGestureRecognizer Command="{Binding IncrementProgressCommand}" /></Border.GestureRecognizers>
                                    <Image WidthRequest="16" HeightRequest="16">
                                        <Image.Source>
                                            <FontImageSource Glyph="{x:Static f:FluentUI.add_24_regular}"
                                                             FontFamily="{x:Static f:FluentUI.FontFamily}"
                                                             Color="{StaticResource Gray400}" Size="16" />
                                        </Image.Source>
                                    </Image>
                                </Border>
                            </HorizontalStackLayout>
                        </VerticalStackLayout>
                        <VerticalStackLayout Spacing="6">
                            <Label Text="Score" Style="{StaticResource Caption1Strong}" />
                            <Entry Text="{Binding EditScore}" Keyboard="Numeric" WidthRequest="80" HorizontalOptions="Start"
                                   FontSize="16" />
                        </VerticalStackLayout>
                        <HorizontalStackLayout Spacing="10">
                            <Button Text="Save"
                                    Command="{Binding SaveListEntryCommand}"
                                    Background="{Binding Converter={StaticResource RainbowAccentConverter}, ConverterParameter=true}"
                                    FontAttributes="Bold"
                                    FontSize="14" Padding="20,8" CornerRadius="12" />
                            <Button Text="Cancel"
                                    Command="{Binding CancelEditCommand}"
                                    BackgroundColor="Transparent"
                                    BorderColor="{StaticResource Gray600}" BorderWidth="1"
                                    FontSize="14" Padding="20,8" CornerRadius="12" />
                            <ActivityIndicator IsRunning="{Binding IsSavingListEntry}" IsVisible="{Binding IsSavingListEntry}"
                                               WidthRequest="24" HeightRequest="24" VerticalOptions="Center" />
                        </HorizontalStackLayout>
                    </VerticalStackLayout>
                </Border>
            </VerticalStackLayout>

            <!-- ============================================ -->
            <!-- 5. DESCRIPTION -->
            <!-- ============================================ -->
            <Border Style="{StaticResource CardStyle}" Padding="16"
                    IsVisible="{Binding HasDescription}">
                <VerticalStackLayout Spacing="8">
                    <Label Text="{Binding Media.Description}"
                           Style="{StaticResource Body2}"
                           TextColor="{StaticResource Gray400}"
                           TextType="Html"
                           MaxLines="{Binding DescriptionMaxLines}"
                           LineBreakMode="TailTruncation" />
                    <Label Style="{StaticResource Caption1Strong}"
                           TextColor="{Binding Converter={StaticResource RainbowAccentConverter}, ConverterParameter='ReadMore'}">
                        <Label.Text>
                            <Binding Path="IsDescriptionExpanded" StringFormat="{}{0}">
                                <Binding.FallbackValue>Read more</Binding.FallbackValue>
                            </Binding>
                        </Label.Text>
                        <Label.Triggers>
                            <DataTrigger TargetType="Label" Binding="{Binding IsDescriptionExpanded}" Value="True">
                                <Setter Property="Text" Value="Show less" />
                            </DataTrigger>
                            <DataTrigger TargetType="Label" Binding="{Binding IsDescriptionExpanded}" Value="False">
                                <Setter Property="Text" Value="Read more" />
                            </DataTrigger>
                        </Label.Triggers>
                        <Label.GestureRecognizers>
                            <TapGestureRecognizer Command="{Binding ToggleDescriptionCommand}" />
                        </Label.GestureRecognizers>
                    </Label>
                </VerticalStackLayout>
            </Border>

            <!-- ============================================ -->
            <!-- 6. ADDITIONAL INFO (Rankings, metadata, trailer) -->
            <!-- ============================================ -->
            <Border Style="{StaticResource CardStyle}" Padding="16">
                <VerticalStackLayout Spacing="10">
                    <!-- Rankings -->
                    <VerticalStackLayout Spacing="4" IsVisible="{Binding HasRankings}"
                                         BindableLayout.ItemsSource="{Binding Rankings}">
                        <BindableLayout.ItemTemplate>
                            <DataTemplate x:DataType="models:MediaRanking">
                                <HorizontalStackLayout Spacing="8">
                                    <Image WidthRequest="16" HeightRequest="16" VerticalOptions="Center">
                                        <Image.Source>
                                            <FontImageSource Glyph="{x:Static f:FluentUI.trophy_24_regular}"
                                                             FontFamily="{x:Static f:FluentUI.FontFamily}"
                                                             Color="{Binding Context, Converter={StaticResource RainbowAccentConverter}}"
                                                             Size="16" />
                                        </Image.Source>
                                    </Image>
                                    <Label Style="{StaticResource Caption1}"
                                           TextColor="{Binding Context, Converter={StaticResource RainbowAccentConverter}}">
                                        <Label.Text>
                                            <MultiBinding StringFormat="#{0} {1}">
                                                <Binding Path="Rank" />
                                                <Binding Path="Context" />
                                            </MultiBinding>
                                        </Label.Text>
                                    </Label>
                                </HorizontalStackLayout>
                            </DataTemplate>
                        </BindableLayout.ItemTemplate>
                    </VerticalStackLayout>

                    <BoxView HeightRequest="1" Color="{AppThemeBinding Light={StaticResource Gray200}, Dark={StaticResource Gray600}}"
                             IsVisible="{Binding HasRankings}" />

                    <!-- Info grid -->
                    <Grid ColumnDefinitions="*,*" RowDefinitions="Auto,Auto,Auto,Auto" ColumnSpacing="12" RowSpacing="10">
                        <VerticalStackLayout Grid.Row="0" Grid.Column="0">
                            <Label Text="Release Window" Style="{StaticResource Caption2}" TextColor="{StaticResource Gray400}" />
                            <Label Text="{Binding ReleaseWindowDisplay}" Style="{StaticResource Body2}" />
                        </VerticalStackLayout>
                        <VerticalStackLayout Grid.Row="0" Grid.Column="1">
                            <Label Text="Source" Style="{StaticResource Caption2}" TextColor="{StaticResource Gray400}" />
                            <Label Text="{Binding SourceDisplay}" Style="{StaticResource Body2}" />
                        </VerticalStackLayout>
                        <VerticalStackLayout Grid.Row="1" Grid.Column="0">
                            <Label Text="Country" Style="{StaticResource Caption2}" TextColor="{StaticResource Gray400}" />
                            <Label Text="{Binding CountryDisplay}" Style="{StaticResource Body2}" />
                        </VerticalStackLayout>
                        <VerticalStackLayout Grid.Row="1" Grid.Column="1">
                            <Label Text="Licensed" Style="{StaticResource Caption2}" TextColor="{StaticResource Gray400}" />
                            <Label Text="{Binding LicensedDisplay}" Style="{StaticResource Body2}" />
                        </VerticalStackLayout>
                        <VerticalStackLayout Grid.Row="2" Grid.Column="0">
                            <Label Text="Rating" Style="{StaticResource Caption2}" TextColor="{StaticResource Gray400}" />
                            <Label Text="{Binding AdultDisplay}" Style="{StaticResource Body2}" />
                        </VerticalStackLayout>
                        <VerticalStackLayout Grid.Row="2" Grid.Column="1" IsVisible="{Binding HasSynonyms}">
                            <Label Text="Synonyms" Style="{StaticResource Caption2}" TextColor="{StaticResource Gray400}" />
                            <Label Text="{Binding SynonymsDisplay}" Style="{StaticResource Caption1}"
                                   MaxLines="3" LineBreakMode="TailTruncation" />
                        </VerticalStackLayout>
                    </Grid>

                    <!-- Trailer button -->
                    <Border StrokeShape="RoundRectangle 12" StrokeThickness="1" Stroke="{StaticResource Gray600}"
                            Padding="12,8" BackgroundColor="Transparent"
                            HorizontalOptions="Start"
                            IsVisible="{Binding HasTrailer}">
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer Command="{Binding OpenUrlCommand}" CommandParameter="{Binding TrailerUrl}" />
                        </Border.GestureRecognizers>
                        <HorizontalStackLayout Spacing="8">
                            <Image WidthRequest="16" HeightRequest="16" VerticalOptions="Center">
                                <Image.Source>
                                    <FontImageSource Glyph="{x:Static f:FluentUI.play_24_regular}"
                                                     FontFamily="{x:Static f:FluentUI.FontFamily}"
                                                     Color="{Binding Converter={StaticResource RainbowAccentConverter}, ConverterParameter='Trailer'}"
                                                     Size="16" />
                                </Image.Source>
                            </Image>
                            <Label Text="Watch Trailer" Style="{StaticResource Caption1Strong}"
                                   TextColor="{Binding Converter={StaticResource RainbowAccentConverter}, ConverterParameter='Trailer'}"
                                   VerticalTextAlignment="Center" />
                        </HorizontalStackLayout>
                    </Border>

                    <!-- AniList link -->
                    <Border StrokeShape="RoundRectangle 12" StrokeThickness="1" Stroke="{StaticResource Gray600}"
                            Padding="12,8" BackgroundColor="Transparent"
                            HorizontalOptions="Start"
                            IsVisible="{Binding Media.SiteUrl, Converter={StaticResource StringNotNullOrEmptyConverter}}">
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer Command="{Binding OpenUrlCommand}" CommandParameter="{Binding Media.SiteUrl}" />
                        </Border.GestureRecognizers>
                        <HorizontalStackLayout Spacing="8">
                            <Image WidthRequest="16" HeightRequest="16" VerticalOptions="Center">
                                <Image.Source>
                                    <FontImageSource Glyph="{x:Static f:FluentUI.globe_24_regular}"
                                                     FontFamily="{x:Static f:FluentUI.FontFamily}"
                                                     Color="{StaticResource Gray400}"
                                                     Size="16" />
                                </Image.Source>
                            </Image>
                            <Label Text="View on AniList" Style="{StaticResource Caption1Strong}"
                                   TextColor="{StaticResource Gray400}"
                                   VerticalTextAlignment="Center" />
                        </HorizontalStackLayout>
                    </Border>
                </VerticalStackLayout>
            </Border>

            <!-- ============================================ -->
            <!-- 7. RELATIONS -->
            <!-- ============================================ -->
            <VerticalStackLayout Spacing="10" IsVisible="{Binding HasRelations}">
                <Border Style="{StaticResource SectionHeaderStyle}"
                        Background="{Binding Converter={StaticResource RainbowAccentConverter}, ConverterParameter=true}">
                    <HorizontalStackLayout Spacing="8">
                        <Image WidthRequest="20" HeightRequest="20" VerticalOptions="Center">
                            <Image.Source>
                                <FontImageSource Glyph="{x:Static f:FluentUI.link_24_regular}"
                                                 FontFamily="{x:Static f:FluentUI.FontFamily}"
                                                 Color="{Binding Converter={StaticResource RainbowAccentConverter}, ConverterParameter='Relations'}"
                                                 Size="20" />
                            </Image.Source>
                        </Image>
                        <Label Text="Relations" Style="{StaticResource Title3}"
                               TextColor="{Binding Converter={StaticResource RainbowAccentConverter}, ConverterParameter='Relations'}" />
                    </HorizontalStackLayout>
                </Border>
                <ScrollView Orientation="Horizontal">
                    <HorizontalStackLayout Spacing="10"
                                           BindableLayout.ItemsSource="{Binding Relations}">
                        <BindableLayout.ItemTemplate>
                            <DataTemplate x:DataType="models:MediaRelationEdge">
                                <Border Style="{StaticResource CardStyle}" Padding="0" WidthRequest="130">
                                    <Border.GestureRecognizers>
                                        <TapGestureRecognizer Command="{Binding Source={RelativeSource AncestorType={x:Type pageModels:MediaDetailsPageModel}}, Path=NavigateToMediaCommand}"
                                                              CommandParameter="{Binding Node.Id}" />
                                    </Border.GestureRecognizers>
                                    <VerticalStackLayout>
                                        <Image Source="{Binding Node.CoverImage.Large}"
                                               Aspect="AspectFill"
                                               HeightRequest="170"
                                               WidthRequest="130">
                                            <Image.Clip>
                                                <RoundRectangleGeometry Rect="0,0,130,170" CornerRadius="16,16,0,0" />
                                            </Image.Clip>
                                        </Image>
                                        <VerticalStackLayout Padding="8,6,8,8" Spacing="2">
                                            <Label Text="{Binding RelationType}"
                                                   Style="{StaticResource Caption2}"
                                                   TextColor="{Binding RelationType, Converter={StaticResource RainbowAccentConverter}}"
                                                   FontAttributes="Bold" />
                                            <Label Text="{Binding Node.DisplayTitle}"
                                                   Style="{StaticResource Caption1}"
                                                   MaxLines="2"
                                                   LineBreakMode="TailTruncation" />
                                        </VerticalStackLayout>
                                    </VerticalStackLayout>
                                </Border>
                            </DataTemplate>
                        </BindableLayout.ItemTemplate>
                    </HorizontalStackLayout>
                </ScrollView>
            </VerticalStackLayout>

            <!-- ============================================ -->
            <!-- 7. CHARACTERS -->
            <!-- ============================================ -->
            <VerticalStackLayout Spacing="10" IsVisible="{Binding HasCharacters}">
                <Border Style="{StaticResource SectionHeaderStyle}"
                        Background="{Binding Converter={StaticResource RainbowAccentConverter}, ConverterParameter=true}">
                    <HorizontalStackLayout Spacing="8">
                        <Image WidthRequest="20" HeightRequest="20" VerticalOptions="Center">
                            <Image.Source>
                                <FontImageSource Glyph="{x:Static f:FluentUI.people_24_regular}"
                                                 FontFamily="{x:Static f:FluentUI.FontFamily}"
                                                 Color="{Binding Converter={StaticResource RainbowAccentConverter}, ConverterParameter='Characters'}"
                                                 Size="20" />
                            </Image.Source>
                        </Image>
                        <Label Text="Characters" Style="{StaticResource Title3}"
                               TextColor="{Binding Converter={StaticResource RainbowAccentConverter}, ConverterParameter='Characters'}" />
                    </HorizontalStackLayout>
                </Border>
                <ScrollView Orientation="Horizontal">
                    <HorizontalStackLayout Spacing="10"
                                           BindableLayout.ItemsSource="{Binding Characters}">
                        <BindableLayout.ItemTemplate>
                            <DataTemplate x:DataType="models:CharacterEdge">
                                <Border Style="{StaticResource CardStyle}" Padding="0" WidthRequest="110">
                                    <VerticalStackLayout>
                                        <Image Source="{Binding Node.Image.Large}"
                                               Aspect="AspectFill"
                                               HeightRequest="140"
                                               WidthRequest="110">
                                            <Image.Clip>
                                                <RoundRectangleGeometry Rect="0,0,110,140" CornerRadius="16,16,0,0" />
                                            </Image.Clip>
                                        </Image>
                                        <VerticalStackLayout Padding="8,6,8,8" Spacing="2">
                                            <Label Text="{Binding Node.Name.Full}"
                                                   Style="{StaticResource Caption1}"
                                                   MaxLines="2"
                                                   LineBreakMode="TailTruncation" />
                                            <Label Text="{Binding Role}"
                                                   Style="{StaticResource Caption2}"
                                                   TextColor="{Binding Role, Converter={StaticResource RainbowAccentConverter}}"
                                                   FontAttributes="Bold" />
                                        </VerticalStackLayout>
                                    </VerticalStackLayout>
                                </Border>
                            </DataTemplate>
                        </BindableLayout.ItemTemplate>
                    </HorizontalStackLayout>
                </ScrollView>
            </VerticalStackLayout>

            <!-- ============================================ -->
            <!-- 8. GENRES -->
            <!-- ============================================ -->
            <FlexLayout Wrap="Wrap" JustifyContent="Start" AlignItems="Center"
                        IsVisible="{Binding HasGenres}"
                        BindableLayout.ItemsSource="{Binding Genres}">
                <BindableLayout.ItemTemplate>
                    <DataTemplate x:DataType="x:String">
                        <Border Style="{StaticResource ChipBorderStyle}" Padding="10,6" Margin="0,0,6,6">
                            <Label Text="{Binding .}" Style="{StaticResource ChipLabelStyle}"
                                   TextColor="{Binding ., Converter={StaticResource RainbowAccentConverter}}" />
                        </Border>
                    </DataTemplate>
                </BindableLayout.ItemTemplate>
            </FlexLayout>

            <!-- ============================================ -->
            <!-- 9. TAGS -->
            <!-- ============================================ -->
            <VerticalStackLayout Spacing="10" IsVisible="{Binding HasTags}">
                <Border Style="{StaticResource SectionHeaderStyle}"
                        Background="{Binding Converter={StaticResource RainbowAccentConverter}, ConverterParameter=true}">
                    <HorizontalStackLayout Spacing="8">
                        <Image WidthRequest="20" HeightRequest="20" VerticalOptions="Center">
                            <Image.Source>
                                <FontImageSource Glyph="{x:Static f:FluentUI.tag_24_regular}"
                                                 FontFamily="{x:Static f:FluentUI.FontFamily}"
                                                 Color="{Binding Converter={StaticResource RainbowAccentConverter}, ConverterParameter='Tags'}"
                                                 Size="20" />
                            </Image.Source>
                        </Image>
                        <Label Text="Tags" Style="{StaticResource Title3}"
                               TextColor="{Binding Converter={StaticResource RainbowAccentConverter}, ConverterParameter='Tags'}" />
                    </HorizontalStackLayout>
                </Border>
                <Border Style="{StaticResource CardStyle}" Padding="12">
                    <VerticalStackLayout Spacing="6"
                                         BindableLayout.ItemsSource="{Binding Tags}">
                        <BindableLayout.ItemTemplate>
                            <DataTemplate x:DataType="models:MediaTag">
                                <Grid ColumnDefinitions="*,50,40" ColumnSpacing="8" Padding="0,4">
                                    <Label Grid.Column="0" Text="{Binding Name}" Style="{StaticResource Caption1}"
                                           MaxLines="1" LineBreakMode="TailTruncation" VerticalTextAlignment="Center" />
                                    <BoxView Grid.Column="1" HeightRequest="6"
                                             CornerRadius="3"
                                             Color="{Binding Name, Converter={StaticResource RainbowAccentConverter}}"
                                             HorizontalOptions="Fill" VerticalOptions="Center"
                                             Opacity="0.5" />
                                    <Label Grid.Column="2" Text="{Binding Rank, StringFormat='{0}%'}"
                                           Style="{StaticResource Caption2}"
                                           TextColor="{Binding Name, Converter={StaticResource RainbowAccentConverter}}"
                                           HorizontalTextAlignment="End" VerticalTextAlignment="Center" />
                                </Grid>
                            </DataTemplate>
                        </BindableLayout.ItemTemplate>
                    </VerticalStackLayout>
                </Border>
            </VerticalStackLayout>

            <!-- ============================================ -->
            <!-- 10. STATS -->
            <!-- ============================================ -->
            <VerticalStackLayout Spacing="10" IsVisible="{Binding HasStats}">
                <Border Style="{StaticResource SectionHeaderStyle}"
                        Background="{Binding Converter={StaticResource RainbowAccentConverter}, ConverterParameter=true}">
                    <HorizontalStackLayout Spacing="8">
                        <Image WidthRequest="20" HeightRequest="20" VerticalOptions="Center">
                            <Image.Source>
                                <FontImageSource Glyph="{x:Static f:FluentUI.data_bar_vertical_24_regular}"
                                                 FontFamily="{x:Static f:FluentUI.FontFamily}"
                                                 Color="{Binding Converter={StaticResource RainbowAccentConverter}, ConverterParameter='Stats'}"
                                                 Size="20" />
                            </Image.Source>
                        </Image>
                        <Label Text="Stats" Style="{StaticResource Title3}"
                               TextColor="{Binding Converter={StaticResource RainbowAccentConverter}, ConverterParameter='Stats'}" />
                    </HorizontalStackLayout>
                </Border>
                <Border Style="{StaticResource CardStyle}" Padding="16">
                    <VerticalStackLayout Spacing="16">
                        <!-- Score Distribution Bar Chart -->
                        <VerticalStackLayout Spacing="4">
                            <Label Text="Score Distribution" Style="{StaticResource Caption1Strong}" TextColor="{StaticResource Gray400}" />
                            <Grid RowDefinitions="100,Auto" HorizontalOptions="Center">
                                <!-- Bars row — all bottom-aligned in the same cell -->
                                <HorizontalStackLayout Grid.Row="0" Spacing="6" VerticalOptions="End"
                                                       BindableLayout.ItemsSource="{Binding ScoreDistribution}">
                                    <BindableLayout.ItemTemplate>
                                        <DataTemplate x:DataType="models:ScoreDistributionItem">
                                            <BoxView HeightRequest="{Binding BarHeight}"
                                                     WidthRequest="24"
                                                     CornerRadius="4,4,0,0"
                                                     Color="{Binding Score, Converter={StaticResource RainbowAccentConverter}}" />
                                        </DataTemplate>
                                    </BindableLayout.ItemTemplate>
                                </HorizontalStackLayout>
                                <!-- Labels row — consistent baseline -->
                                <HorizontalStackLayout Grid.Row="1" Spacing="6" Margin="0,2,0,0"
                                                       BindableLayout.ItemsSource="{Binding ScoreDistribution}">
                                    <BindableLayout.ItemTemplate>
                                        <DataTemplate x:DataType="models:ScoreDistributionItem">
                                            <Label Text="{Binding Score}"
                                                   WidthRequest="24"
                                                   Style="{StaticResource Caption2}"
                                                   TextColor="{StaticResource Gray400}"
                                                   HorizontalTextAlignment="Center"
                                                   FontSize="9" />
                                        </DataTemplate>
                                    </BindableLayout.ItemTemplate>
                                </HorizontalStackLayout>
                            </Grid>
                        </VerticalStackLayout>
                        <!-- Status Distribution Pills -->
                        <VerticalStackLayout Spacing="4">
                            <Label Text="Status Distribution" Style="{StaticResource Caption1Strong}" TextColor="{StaticResource Gray400}" />
                            <FlexLayout Wrap="Wrap" JustifyContent="Start" AlignItems="Center"
                                        BindableLayout.ItemsSource="{Binding StatusDistribution}">
                                <BindableLayout.ItemTemplate>
                                    <DataTemplate x:DataType="models:StatusDistribution">
                                        <Border Style="{StaticResource ChipBorderStyle}" Padding="10,6" Margin="0,0,6,6">
                                            <HorizontalStackLayout Spacing="6">
                                                <Label Text="{Binding Status}" Style="{StaticResource ChipLabelStyle}"
                                                       TextColor="{Binding Status, Converter={StaticResource RainbowAccentConverter}}" />
                                                <Label Text="{Binding Amount}" Style="{StaticResource Caption2}"
                                                       TextColor="{StaticResource Gray400}" VerticalTextAlignment="Center" />
                                            </HorizontalStackLayout>
                                        </Border>
                                    </DataTemplate>
                                </BindableLayout.ItemTemplate>
                            </FlexLayout>
                        </VerticalStackLayout>
                    </VerticalStackLayout>
                </Border>
            </VerticalStackLayout>

            <!-- ============================================ -->
            <!-- 11. RECOMMENDATIONS -->
            <!-- ============================================ -->
            <VerticalStackLayout Spacing="10" IsVisible="{Binding HasRecommendations}">
                <Border Style="{StaticResource SectionHeaderStyle}"
                        Background="{Binding Converter={StaticResource RainbowAccentConverter}, ConverterParameter=true}">
                    <HorizontalStackLayout Spacing="8">
                        <Image WidthRequest="20" HeightRequest="20" VerticalOptions="Center">
                            <Image.Source>
                                <FontImageSource Glyph="{x:Static f:FluentUI.sparkle_24_regular}"
                                                 FontFamily="{x:Static f:FluentUI.FontFamily}"
                                                 Color="{Binding Converter={StaticResource RainbowAccentConverter}, ConverterParameter='Recommendations'}"
                                                 Size="20" />
                            </Image.Source>
                        </Image>
                        <Label Text="Recommendations" Style="{StaticResource Title3}"
                               TextColor="{Binding Converter={StaticResource RainbowAccentConverter}, ConverterParameter='Recommendations'}" />
                    </HorizontalStackLayout>
                </Border>
                <ScrollView Orientation="Horizontal">
                    <HorizontalStackLayout Spacing="10"
                                           BindableLayout.ItemsSource="{Binding Recommendations}">
                        <BindableLayout.ItemTemplate>
                            <DataTemplate x:DataType="models:MediaRecommendationNode">
                                <Border Style="{StaticResource CardStyle}" Padding="0" WidthRequest="130">
                                    <Border.GestureRecognizers>
                                        <TapGestureRecognizer Command="{Binding Source={RelativeSource AncestorType={x:Type pageModels:MediaDetailsPageModel}}, Path=NavigateToMediaCommand}"
                                                              CommandParameter="{Binding MediaRecommendation.Id}" />
                                    </Border.GestureRecognizers>
                                    <VerticalStackLayout>
                                        <Image Source="{Binding MediaRecommendation.CoverImage.Large}"
                                               Aspect="AspectFill"
                                               HeightRequest="170"
                                               WidthRequest="130">
                                            <Image.Clip>
                                                <RoundRectangleGeometry Rect="0,0,130,170" CornerRadius="16,16,0,0" />
                                            </Image.Clip>
                                        </Image>
                                        <VerticalStackLayout Padding="8,6,8,8" Spacing="2">
                                            <Label Text="{Binding MediaRecommendation.DisplayTitle}"
                                                   Style="{StaticResource Caption1}"
                                                   MaxLines="2"
                                                   LineBreakMode="TailTruncation" />
                                        </VerticalStackLayout>
                                    </VerticalStackLayout>
                                </Border>
                            </DataTemplate>
                        </BindableLayout.ItemTemplate>
                    </HorizontalStackLayout>
                </ScrollView>
            </VerticalStackLayout>

            <!-- ============================================ -->
            <!-- 12. STAFF -->
            <!-- ============================================ -->
            <VerticalStackLayout Spacing="10" IsVisible="{Binding HasStaff}">
                <Border Style="{StaticResource SectionHeaderStyle}"
                        Background="{Binding Converter={StaticResource RainbowAccentConverter}, ConverterParameter=true}">
                    <HorizontalStackLayout Spacing="8">
                        <Image WidthRequest="20" HeightRequest="20" VerticalOptions="Center">
                            <Image.Source>
                                <FontImageSource Glyph="{x:Static f:FluentUI.person_24_regular}"
                                                 FontFamily="{x:Static f:FluentUI.FontFamily}"
                                                 Color="{Binding Converter={StaticResource RainbowAccentConverter}, ConverterParameter='Staff'}"
                                                 Size="20" />
                            </Image.Source>
                        </Image>
                        <Label Text="Staff" Style="{StaticResource Title3}"
                               TextColor="{Binding Converter={StaticResource RainbowAccentConverter}, ConverterParameter='Staff'}" />
                    </HorizontalStackLayout>
                </Border>
                <ScrollView Orientation="Horizontal">
                    <HorizontalStackLayout Spacing="10"
                                           BindableLayout.ItemsSource="{Binding Staff}">
                        <BindableLayout.ItemTemplate>
                            <DataTemplate x:DataType="models:StaffEdge">
                                <Border Style="{StaticResource CardStyle}" Padding="0" WidthRequest="110">
                                    <VerticalStackLayout>
                                        <Image Source="{Binding Node.Image.Medium}"
                                               Aspect="AspectFill"
                                               HeightRequest="140"
                                               WidthRequest="110">
                                            <Image.Clip>
                                                <RoundRectangleGeometry Rect="0,0,110,140" CornerRadius="16,16,0,0" />
                                            </Image.Clip>
                                        </Image>
                                        <VerticalStackLayout Padding="8,6,8,8" Spacing="2">
                                            <Label Text="{Binding Node.Name.Full}"
                                                   Style="{StaticResource Caption1}"
                                                   MaxLines="2"
                                                   LineBreakMode="TailTruncation" />
                                            <Label Text="{Binding Role}"
                                                   Style="{StaticResource Caption2}"
                                                   TextColor="{Binding Role, Converter={StaticResource RainbowAccentConverter}}"
                                                   FontAttributes="Bold" />
                                        </VerticalStackLayout>
                                    </VerticalStackLayout>
                                </Border>
                            </DataTemplate>
                        </BindableLayout.ItemTemplate>
                    </HorizontalStackLayout>
                </ScrollView>
            </VerticalStackLayout>

            <!-- ============================================ -->
            <!-- 13. STREAMING EPISODES -->
            <!-- ============================================ -->
            <VerticalStackLayout Spacing="10" IsVisible="{Binding HasStreamingEpisodes}">
                <Border Style="{StaticResource SectionHeaderStyle}"
                        Background="{Binding Converter={StaticResource RainbowAccentConverter}, ConverterParameter=true}">
                    <HorizontalStackLayout Spacing="8">
                        <Image WidthRequest="20" HeightRequest="20" VerticalOptions="Center">
                            <Image.Source>
                                <FontImageSource Glyph="{x:Static f:FluentUI.play_24_regular}"
                                                 FontFamily="{x:Static f:FluentUI.FontFamily}"
                                                 Color="{Binding Converter={StaticResource RainbowAccentConverter}, ConverterParameter='Streaming'}"
                                                 Size="20" />
                            </Image.Source>
                        </Image>
                        <Label Text="Streaming" Style="{StaticResource Title3}"
                               TextColor="{Binding Converter={StaticResource RainbowAccentConverter}, ConverterParameter='Streaming'}" />
                    </HorizontalStackLayout>
                </Border>
                <VerticalStackLayout Spacing="8"
                                     BindableLayout.ItemsSource="{Binding StreamingEpisodes}">
                    <BindableLayout.ItemTemplate>
                        <DataTemplate x:DataType="models:MediaStreamingEpisode">
                            <Border Style="{StaticResource ListRowStyle}" Padding="0">
                                <Border.GestureRecognizers>
                                    <TapGestureRecognizer Command="{Binding Source={RelativeSource AncestorType={x:Type pageModels:MediaDetailsPageModel}}, Path=OpenUrlCommand}"
                                                          CommandParameter="{Binding Url}" />
                                </Border.GestureRecognizers>
                                <Grid ColumnDefinitions="80,*" ColumnSpacing="10">
                                    <Image Grid.Column="0" Source="{Binding Thumbnail}"
                                           Aspect="AspectFill"
                                           WidthRequest="80" HeightRequest="50">
                                        <Image.Clip>
                                            <RoundRectangleGeometry Rect="0,0,80,50" CornerRadius="14,0,0,14" />
                                        </Image.Clip>
                                    </Image>
                                    <VerticalStackLayout Grid.Column="1" VerticalOptions="Center" Spacing="2" Padding="0,8,8,8">
                                        <Label Text="{Binding Title}" Style="{StaticResource Caption1}"
                                               MaxLines="2" LineBreakMode="TailTruncation" />
                                        <Label Text="{Binding Site}" Style="{StaticResource Caption2}"
                                               TextColor="{Binding Site, Converter={StaticResource RainbowAccentConverter}}" />
                                    </VerticalStackLayout>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </BindableLayout.ItemTemplate>
                </VerticalStackLayout>
            </VerticalStackLayout>

            <!-- ============================================ -->
            <!-- 14. EXTERNAL LINKS -->
            <!-- ============================================ -->
            <VerticalStackLayout Spacing="10" IsVisible="{Binding HasExternalLinks}">
                <Border Style="{StaticResource SectionHeaderStyle}"
                        Background="{Binding Converter={StaticResource RainbowAccentConverter}, ConverterParameter=true}">
                    <HorizontalStackLayout Spacing="8">
                        <Image WidthRequest="20" HeightRequest="20" VerticalOptions="Center">
                            <Image.Source>
                                <FontImageSource Glyph="{x:Static f:FluentUI.globe_24_regular}"
                                                 FontFamily="{x:Static f:FluentUI.FontFamily}"
                                                 Color="{Binding Converter={StaticResource RainbowAccentConverter}, ConverterParameter='Links'}"
                                                 Size="20" />
                            </Image.Source>
                        </Image>
                        <Label Text="External Links" Style="{StaticResource Title3}"
                               TextColor="{Binding Converter={StaticResource RainbowAccentConverter}, ConverterParameter='Links'}" />
                    </HorizontalStackLayout>
                </Border>
                <FlexLayout Wrap="Wrap" JustifyContent="Start" AlignItems="Center"
                            BindableLayout.ItemsSource="{Binding ExternalLinks}">
                    <BindableLayout.ItemTemplate>
                        <DataTemplate x:DataType="models:MediaExternalLink">
                            <Border Style="{StaticResource ChipBorderStyle}" Padding="10,6" Margin="0,0,6,6">
                                <Border.GestureRecognizers>
                                    <TapGestureRecognizer Command="{Binding Source={RelativeSource AncestorType={x:Type pageModels:MediaDetailsPageModel}}, Path=OpenUrlCommand}"
                                                          CommandParameter="{Binding Url}" />
                                </Border.GestureRecognizers>
                                <Label Text="{Binding Site}" Style="{StaticResource ChipLabelStyle}"
                                       TextColor="{Binding Site, Converter={StaticResource RainbowAccentConverter}}" />
                            </Border>
                        </DataTemplate>
                    </BindableLayout.ItemTemplate>
                </FlexLayout>
            </VerticalStackLayout>

            <!-- ============================================ -->
            <!-- BOTTOM SPACER -->
            <!-- ============================================ -->
            <BoxView HeightRequest="24" Color="Transparent" />

        </VerticalStackLayout>
    </ScrollView>
</ContentView>
