<?xml version="1.0" encoding="UTF-8" ?>
<Shell
    x:Class="AniSprinkles.AppShell"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:pages="clr-namespace:AniSprinkles.Pages"
    Title="AniSprinkles"
    FlyoutBehavior="Flyout">

    <FlyoutItem Title="My Anime" Route="my-anime">
        <ShellContent ContentTemplate="{DataTemplate pages:MyAnimePage}" />
    </FlyoutItem>

    <FlyoutItem Title="Settings" Route="settings">
        <ShellContent ContentTemplate="{DataTemplate pages:SettingsPage}" />
    </FlyoutItem>
</Shell>
