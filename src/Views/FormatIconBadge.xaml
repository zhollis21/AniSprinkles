<?xml version="1.0" encoding="utf-8" ?>
<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:icons="clr-namespace:IconFont.Maui.FluentIcons;assembly=IconFont.Maui.FluentIcons"
             xmlns:views="clr-namespace:AniSprinkles.Views"
             x:Class="AniSprinkles.Views.FormatIconBadge"
             x:DataType="views:FormatIconBadge"
             x:Name="Self"
             IsVisible="{Binding Format, Source={x:Reference Self}, Converter={StaticResource StringNotNullOrEmptyConverter}}">

    <Border StrokeShape="RoundRectangle 8"
            StrokeThickness="0"
            BackgroundColor="#99000000"
            Padding="5,3">
        <Label Text="{Binding Format, Source={x:Reference Self}, Converter={StaticResource MediaFormatIconConverter}}"
               FontFamily="{x:Static icons:FluentIconsRegular.FontFamily}"
               TextColor="{AppThemeBinding Light=#333333, Dark=White}"
               FontSize="{Binding Size, Source={x:Reference Self}}"
               WidthRequest="{Binding Size, Source={x:Reference Self}}"
               HeightRequest="{Binding Size, Source={x:Reference Self}}"
               HorizontalTextAlignment="Center"
               VerticalTextAlignment="Center"
               AutomationProperties.IsInAccessibleTree="False" />
    </Border>
</ContentView>
