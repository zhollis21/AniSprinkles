<?xml version="1.0" encoding="utf-8" ?>
<toolkit:Popup xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
               xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
               xmlns:toolkit="http://schemas.microsoft.com/dotnet/2022/maui/toolkit"
               xmlns:icons="clr-namespace:IconFont.Maui.FluentIcons;assembly=IconFont.Maui.FluentIcons"
               x:Class="AniSprinkles.Views.MoveToListPopup"
               x:TypeArguments="x:Object"
               BackgroundColor="Transparent"
               VerticalOptions="End">

    <Border StrokeShape="RoundRectangle 20,20,0,0"
            StrokeThickness="0"
            Padding="0"
            HorizontalOptions="Fill"
            WidthRequest="400"
            Background="{AppThemeBinding Light={StaticResource LightSecondaryBackground},
                                         Dark={StaticResource DarkSecondaryBackground}}">
        <VerticalStackLayout Spacing="0" Padding="0">

            <!-- Drag handle -->
            <BoxView HeightRequest="4" WidthRequest="36"
                     CornerRadius="2"
                     Color="{StaticResource Gray500}"
                     HorizontalOptions="Center"
                     Margin="0,10,0,6" />

            <!-- Anime title -->
            <Label x:Name="TitleLabel"
                   Style="{StaticResource Title3}"
                   HorizontalTextAlignment="Center"
                   MaxLines="2"
                   LineBreakMode="TailTruncation"
                   Margin="20,4,20,2" />

            <!-- Subtitle -->
            <Label Text="Move to..."
                   Style="{StaticResource Caption1}"
                   TextColor="{StaticResource Gray400}"
                   HorizontalTextAlignment="Center"
                   Margin="0,0,0,8" />

            <!-- Divider -->
            <BoxView HeightRequest="1" Color="{StaticResource Gray600}" Opacity="0.3" />

            <!-- Status options container -->
            <VerticalStackLayout x:Name="StatusOptionsLayout" Spacing="0" Padding="8,4">
                <!-- Status rows are added dynamically in code-behind -->
            </VerticalStackLayout>

            <!-- Divider before delete -->
            <BoxView HeightRequest="1" Color="{StaticResource Gray600}" Opacity="0.3" />

            <!-- Remove from list -->
            <Border StrokeShape="RoundRectangle 8" StrokeThickness="0" Padding="14,12"
                    BackgroundColor="Transparent" Margin="8,4,8,8">
                <Border.GestureRecognizers>
                    <TapGestureRecognizer Tapped="OnDeleteTapped" />
                </Border.GestureRecognizers>
                <Grid ColumnDefinitions="Auto,*" ColumnSpacing="12">
                    <Image Grid.Column="0" WidthRequest="20" HeightRequest="20" VerticalOptions="Center">
                        <Image.Source>
                            <FontImageSource Glyph="{x:Static icons:FluentIconsRegular.Delete24}"
                                             FontFamily="{x:Static icons:FluentIconsRegular.FontFamily}"
                                             Color="{StaticResource RainbowRed}" Size="20" />
                        </Image.Source>
                    </Image>
                    <Label Grid.Column="1" Text="Remove from List"
                           Style="{StaticResource Body2}"
                           TextColor="{StaticResource RainbowRed}"
                           VerticalTextAlignment="Center" />
                </Grid>
            </Border>

        </VerticalStackLayout>
    </Border>

</toolkit:Popup>
